 1185:     class NativeTransformerLM(nn.Module):
 1186:         def __init__(self, model_config: dict):
 1187:             super().__init__()
 1188:             self.vocab_size = int(model_config.get("vocab_size", tokenizer.vocab_size))
 1189:             self.max_seq_length = int(model_config["max_seq_length"])
 1190:             self.token_embedding = nn.Embedding(self.vocab_size, int(model_config["hidden_size"]))
 1191:             self.position_embedding = nn.Embedding(self.max_seq_length, int(model_config["hidden_size"]))
 1192:             self.dropout = nn.Dropout(float(model_config["dropout"]))
 1193:             self.blocks = nn.ModuleList(
 1194:                 [
 1195:                     Block(
 1196:                         hidden_size=int(model_config["hidden_size"]),
 1197:                         num_heads=int(model_config["num_heads"]),
 1198:                         mlp_ratio=float(model_config["mlp_ratio"]),
 1199:                         dropout=float(model_config["dropout"]),
 1200:                     )
 1201:                     for _ in range(int(model_config["num_layers"]))
 1202:                 ]
 1203:             )
 1204:             self.norm = nn.LayerNorm(int(model_config["hidden_size"]))
 1205:             self.lm_head = nn.Linear(int(model_config["hidden_size"]), self.vocab_size, bias=False)
 1206:             self.lm_head.weight = self.token_embedding.weight
 1207: 
 1208:         def forward(self, input_ids):
 1209:             batch_size, seq_len = input_ids.shape
 1210:             if seq_len > self.max_seq_length:
 1211:                 raise ValueError("sequence length exceeds model max_seq_length")
 1212:             positions = torch.arange(0, seq_len, device=input_ids.device).unsqueeze(0).expand(batch_size, seq_len)
 1213:             x = self.token_embedding(input_ids) + self.position_embedding(positions)
 1214:             x = self.dropout(x)
 1215:             for block in self.blocks:
 1216:                 x = block(x)
 1217:             x = self.norm(x)
 1218:             return self.lm_head(x)
