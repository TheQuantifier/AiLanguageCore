  466: def render_messages(messages: list[dict], add_generation_prompt: bool) -> str:
  467:     parts = []
  468:     for message in messages:
  469:         role = message["role"]
  470:         prefix = ROLE_PREFIXES[role]
  471:         parts.append(prefix)
  472:         parts.append(message["content"])
  473:         parts.append("\n")
  474:     if add_generation_prompt:
  475:         parts.append(ROLE_PREFIXES["assistant"])
  476:     return "".join(parts)
