 1166:     class Block(nn.Module):
 1167:         def __init__(self, hidden_size: int, num_heads: int, mlp_ratio: float, dropout: float):
 1168:             super().__init__()
 1169:             mlp_hidden = int(hidden_size * mlp_ratio)
 1170:             self.norm_1 = nn.LayerNorm(hidden_size)
 1171:             self.attn = CausalSelfAttention(hidden_size, num_heads, dropout)
 1172:             self.norm_2 = nn.LayerNorm(hidden_size)
 1173:             self.mlp = nn.Sequential(
 1174:                 nn.Linear(hidden_size, mlp_hidden),
 1175:                 nn.GELU(),
 1176:                 nn.Linear(mlp_hidden, hidden_size),
 1177:                 nn.Dropout(dropout),
 1178:             )
 1179: 
 1180:         def forward(self, x):
 1181:             x = x + self.attn(self.norm_1(x))
 1182:             x = x + self.mlp(self.norm_2(x))
 1183:             return x
