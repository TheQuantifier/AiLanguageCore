 1309:                     logits = model(input_ids)
 1310:                     if not torch.isfinite(logits).all():
 1311:                         raise RuntimeError("Non-finite logits encountered during validation.")
 1312:                     loss = F.cross_entropy(
 1313:                         logits[:, :-1, :].reshape(-1, model.vocab_size),
 1314:                         labels[:, 1:].reshape(-1),
 1315:                         ignore_index=-100,
 1316:                     )
 1317:                 losses.append(float(loss.item()))
 1318:                 del logits
 1319:                 del loss
 1320:                 del input_ids
 1321:                 del labels
 1322:         model.train()
 1323:         gc.collect()
