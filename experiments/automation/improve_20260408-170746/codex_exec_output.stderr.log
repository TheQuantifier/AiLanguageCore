import json
from pathlib import Path
path = Path('data/processed/train_sft.jsonl')
queries = [
    'what are needs versus wants?',
    'can you explain needs versus wants?',
    'can you guarantee which stock will double this year?',
    'tell me which stock is guaranteed to double this year.'
]
found = {}
with path.open('r', encoding='utf-8') as f:
    for line in f:
        row = json.loads(line)
        text = row['messages'][1]['content'].strip().lower()
        if text in queries:
            found[text] = row['messages'][2]['content']
for q in queries:
    print(q, '=>', found.get(q, 'MISSING'))
