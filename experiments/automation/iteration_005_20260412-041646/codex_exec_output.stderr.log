                "num_layers": int(config["num_layers"]),
                "num_heads": int(config["num_heads"]),
                "mlp_ratio": float(config["mlp_ratio"]),
                "dropout": float(config["dropout"]),
            },
        )
        save_json(output_dir / "training_config.json", config)
        status_writer.update(
