$iteration = 0
$lastSummaryLine = $null

try {
    if ($Command -eq 'improve') {
        $timestamp = Get-Date -Format 'yyyyMMdd-HHmmss'
        $iterationLabel = 'improve'
        $iterationDir = Join-Path $logRoot "improve_$timestamp"
