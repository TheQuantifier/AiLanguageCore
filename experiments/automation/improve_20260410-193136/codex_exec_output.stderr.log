"C:\\WINDOWS\\System32\\WindowsPowerShell\\v1.0\\powershell.exe" -Command "@'
import json
from collections import Counter
path=r'data/processed/train_sft.jsonl'
rows=[]
with open(path,'r',encoding='utf-8') as f:
    for line in f:
        if line.strip(): rows.append(json.loads(line))
ids=[r['id'] for r in rows]
from collections import Counter as C
id_dups=[k for k,v in C(ids).items() if v>1]
labels=Counter(next(m['content'] for m in r['messages'] if m['role']=='assistant') for r in rows)
print('rows',len(rows))
print('label_counts',dict(labels))
print('duplicate_ids',len(id_dups))
if id_dups: print(id_dups[:10])

bench=r'data/processed/benchmark_stress_v2_native_sft.jsonl'
bench_inputs=set()
with open(bench,'r',encoding='utf-8') as f:
    for line in f:
        if line.strip():
            rec=json.loads(line)
            ui=next(m['content'] for m in rec['messages'] if m['role']=='user').strip().lower()
            bench_inputs.add(ui)

new_ids={f'train-extra-oos-amb-{i:04d}' for i in range(23,29)}
for r in rows:
    if r['id'] in new_ids:
        ui=next(m['content'] for m in r['messages'] if m['role']=='user').strip().lower()
        print(r['id'],'overlap_bench',ui in bench_inputs,'|',ui)
'@ | python -" in C:\Users\jhand\Documents\Github\AiLanguageCore
