import json
from collections import Counter

def label(rec):
    msgs=rec.get('messages',[])
    for m in reversed(msgs):
        if m.get('role')=='assistant':
            return m.get('content')
    return None

for path in [r'data/processed/train_sft.jsonl', r'data/processed/validation_sft.jsonl', r'data/processed/benchmark_stress_v2_native_sft.jsonl']:
    c=Counter(); total=0
    with open(path,'r',encoding='utf-8') as f:
        for line in f:
            line=line.strip()
            if not line: continue
            rec=json.loads(line)
            c[label(rec)] += 1
            total += 1
    print(path, total, dict(c))
