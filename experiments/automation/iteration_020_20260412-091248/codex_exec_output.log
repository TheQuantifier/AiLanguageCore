  482: @dataclass
  483: class Example:
  484:     input_ids: list[int]
  485:     label_ids: list[int]
  486:     response_type: str
  487: 
  488: 
  489: def fit_prompt_and_answer(prompt_ids: list[int], answer_ids: list[int], max_seq_length: int) -> tuple[list[int], list[int]]:
  490:     full_input_ids = prompt_ids + answer_ids
  491:     full_label_ids = ([-100] * len(prompt_ids)) + answer_ids
  492:     if len(full_input_ids) <= max_seq_length:
  493:         return full_input_ids, full_label_ids
  494: 
  495:     if len(answer_ids) >= max_seq_length:
  496:         trimmed_answer = answer_ids[-max_seq_length:]
  497:         return trimmed_answer, trimmed_answer[:]
  498: 
  499:     prompt_budget = max_seq_length - len(answer_ids)
  500:     trimmed_prompt = prompt_ids[-prompt_budget:] if prompt_budget > 0 else []
  501:     input_ids = trimmed_prompt + answer_ids
  502:     label_ids = ([-100] * len(trimmed_prompt)) + answer_ids
  503:     return input_ids, label_ids
  504: 
  505: 
  506: def build_examples(rows: list[dict], tokenizer: ByteTokenizer, max_seq_length: int) -> list[Example]:
  507:     examples = []
  508:     for row in rows:
  509:         prompt_text = render_messages(row["messages"][:2], add_generation_prompt=True)
  510:         answer_text = row["messages"][2]["content"]
  511: 
  512:         prompt_ids = [tokenizer.bos_token_id] + tokenizer.encode(prompt_text, add_special_tokens=False)
  513:         answer_ids = tokenizer.encode(answer_text, add_special_tokens=False) + [tokenizer.eos_token_id]
  514:         input_ids, label_ids = fit_prompt_and_answer(prompt_ids, answer_ids, max_seq_length)
  515:         examples.append(
  516:             Example(
  517:                 input_ids=input_ids,
  518:                 label_ids=label_ids,
  519:                 response_type=answer_text,
  520:             )
  521:         )
  522:     return examples
  523: 
  524: 
  525: def build_tokenizer_from_rows(*row_sets: list[dict]) -> ByteTokenizer:
  526:     chars = set()
  527:     for prefix in ROLE_PREFIXES.values():
  528:         chars.update(prefix)
  529:     for rows in row_sets:
  530:         for row in rows:
  531:             for message in row["messages"]:
  532:                 chars.update(message["content"])
  533:     return ByteTokenizer(chars=sorted(chars))
  534: 
  535: 
  536: def collect_required_tokenizer_chars(*row_sets: list[dict]) -> set[str]:
  537:     chars: set[str] = set()
  538:     for prefix in ROLE_PREFIXES.values():
  539:         chars.update(prefix)
  540:     for rows in row_sets:
  541:         for row in rows:
  542:             for message in row["messages"]:
  543:                 chars.update(message["content"])
  544:     return chars
  545: 
  546: 
  547: def create_batches(examples: list[Example], batch_size: int, shuffle: bool) -> list[list[Example]]:
  548:     items = examples[:]
  549:     if shuffle:
  550:         random.shuffle(items)
  551:     return [items[index : index + batch_size] for index in range(0, len(items), batch_size)]
  552: 
  553: 
  554: def collate_batch(batch: list[Example], tokenizer: ByteTokenizer, torch_module) -> tuple[object, object]:
  555:     max_length = max(len(example.input_ids) for example in batch)
  556:     input_rows = []
  557:     label_rows = []
  558:     for example in batch:
  559:         pad_count = max_length - len(example.input_ids)
  560:         input_rows.append(example.input_ids + ([tokenizer.pad_token_id] * pad_count))
  561:         label_rows.append(example.label_ids + ([-100] * pad_count))
  562:     input_ids = torch_module.tensor(input_rows, dtype=torch_module.long)
  563:     labels = torch_module.tensor(label_rows, dtype=torch_module.long)
  564:     return input_ids, labels
  565: 
  566: 
  567: def compute_response_type_weights(
  568:     examples: list[Example],
  569:     enabled: bool,
  570:     weight_power: float,
  571: ) -> dict[str, float]:
  572:     if not enabled or not examples:
  573:         return {}
  574: 
  575:     counts: dict[str, int] = {}
  576:     for example in examples:
  577:         counts[example.response_type] = counts.get(example.response_type, 0) + 1
  578: 
  579:     if not counts:
  580:         return {}
  581: 
  582:     total_examples = len(examples)
  583:     total_classes = len(counts)
  584:     normalized_weights = {
  585:         response_type: ((total_examples / (total_classes * count)) ** weight_power)
  586:         for response_type, count in counts.items()
  587:     }
  588:     mean_weight = sum(normalized_weights.values()) / len(normalized_weights)
  589:     if mean_weight <= 0:
  590:         return {}
  591:     return {
  592:         response_type: (weight / mean_weight)
  593:         for response_type, weight in normalized_weights.items()
  594:     }
  595: 
  596: 
  597: def compute_batch_loss(
  598:     logits,
  599:     labels,
  600:     batch: list[Example],
  601:     vocab_size: int,
  602:     class_weights: dict[str, float],
  603:     torch_module,
  604: ) -> object:
  605:     shifted_logits = logits[:, :-1, :].reshape(-1, vocab_size)
  606:     shifted_labels = labels[:, 1:].reshape(-1)
  607:     if not class_weights:
  608:         return torch_module.nn.functional.cross_entropy(
  609:             shifted_logits,
  610:             shifted_labels,
  611:             ignore_index=-100,
  612:         )
  613: 
  614:     token_losses = torch_module.nn.functional.cross_entropy(
  615:         shifted_logits,
  616:         shifted_labels,
  617:         ignore_index=-100,
  618:         reduction="none",
  619:     ).view(labels.shape[0], labels.shape[1] - 1)
  620:     valid_mask = (labels[:, 1:] != -100).to(token_losses.dtype)
  621:     token_counts = valid_mask.sum(dim=1).clamp_min(1.0)
  622:     example_losses = (token_losses * valid_mask).sum(dim=1) / token_counts
  623:     weight_values = [
  624:         float(class_weights.get(example.response_type, 1.0))
  625:         for example in batch
  626:     ]
  627:     example_weights = torch_module.tensor(weight_values, dtype=example_losses.dtype, device=example_losses.device)
  628:     return (example_losses * example_weights).sum() / example_weights.sum().clamp_min(1.0)
  629: 
