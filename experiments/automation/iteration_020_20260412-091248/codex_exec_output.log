  395: def render_messages(messages: list[dict], add_generation_prompt: bool) -> str:
  396:     parts = []
  397:     for message in messages:
  398:         role = message["role"]
  399:         prefix = ROLE_PREFIXES[role]
  400:         parts.append(prefix)
  401:         parts.append(message["content"])
  402:         parts.append("\n")
  403:     if add_generation_prompt:
  404:         parts.append(ROLE_PREFIXES["assistant"])
  405:     return "".join(parts)
