  839: class DirectMLAdamW:
  840:     def __init__(
  841:         self,
  842:         torch_module,
  843:         params,
  844:         lr: float,
  845:         weight_decay: float = 0.01,
  846:         betas: tuple[float, float] = (0.9, 0.999),
  847:         eps: float = 1e-8,
  848:     ) -> None:
  849:         self.torch = torch_module
  850:         self.params = [param for param in params if param.requires_grad]
  851:         self.lr = float(lr)
  852:         self.weight_decay = float(weight_decay)
  853:         self.beta1 = float(betas[0])
  854:         self.beta2 = float(betas[1])
  855:         self.eps = float(eps)
  856:         self.step_count = 0
  857:         self.state: dict[int, dict[str, object]] = {}
  858: 
  859:     def zero_grad(self, set_to_none: bool = True) -> None:
  860:         for param in self.params:
  861:             if param.grad is None:
  862:                 continue
  863:             if set_to_none:
  864:                 param.grad = None
  865:             else:
  866:                 param.grad.zero_()
  867: 
  868:     def step(self) -> None:
  869:         self.step_count += 1
  870:         bias_correction1 = 1.0 - (self.beta1 ** self.step_count)
  871:         bias_correction2 = 1.0 - (self.beta2 ** self.step_count)
  872: 
  873:         with self.torch.no_grad():
  874:             for param in self.params:
  875:                 grad = param.grad
  876:                 if grad is None:
  877:                     continue
  878:                 if grad.is_sparse:
  879:                     raise RuntimeError("DirectMLAdamW does not support sparse gradients.")
