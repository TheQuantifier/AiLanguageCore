  368: def resolve_init_model_path(path_value: str | Path | None, repo_root: Path) -> Path | None:
  369:     if not path_value:
  370:         return None
  371:     value = str(path_value).strip()
  372:     if not value:
  373:         return None
  374:     if value.startswith("latest:") or value.startswith("best:"):
  375:         mode = value.split(":", 1)[0]
  376:         parts = value.split(":")
  377:         try:
  378:             if len(parts) == 2:
  379:                 if mode == "latest":
  380:                     return find_latest_completed_run(repo_root, None, parts[1])
  381:                 return find_best_completed_run(repo_root, None, parts[1])
  382:             if len(parts) == 3:
  383:                 if mode == "latest":
  384:                     return find_latest_completed_run(repo_root, parts[1], parts[2])
  385:                 return find_best_completed_run(repo_root, parts[1], parts[2])
  386:         except FileNotFoundError:
  387:             return None
  388:         raise ValueError(
  389:             "init_from_model_path must use latest:<category>, latest:<type>:<category>, "
  390:             "best:<category>, or best:<type>:<category>"
  391:         )
  392:     return resolve_path(value, repo_root)
