  704: def build_cpu_state_dict(model) -> dict:
  705:     return {name: tensor.detach().cpu() for name, tensor in model.state_dict().items()}
  706: 
  707: 
  708: def build_token_id_remap(source_tokenizer: ByteTokenizer, target_tokenizer: ByteTokenizer) -> list[tuple[int, int]]:
  709:     pairs: list[tuple[int, int]] = []
  710: 
  711:     for char, source_id in source_tokenizer.char_to_id.items():
  712:         target_id = target_tokenizer.char_to_id.get(char)
  713:         if target_id is not None:
  714:             pairs.append((source_id, target_id))
  715: 
  716:     special_pairs = [
  717:         (source_tokenizer.pad_token_id, target_tokenizer.pad_token_id),
  718:         (source_tokenizer.bos_token_id, target_tokenizer.bos_token_id),
  719:         (source_tokenizer.eos_token_id, target_tokenizer.eos_token_id),
  720:     ]
  721:     for source_id, target_id in special_pairs:
  722:         pairs.append((int(source_id), int(target_id)))
  723: 
  724:     unique_pairs: list[tuple[int, int]] = []
  725:     seen_targets: set[int] = set()
  726:     for source_id, target_id in pairs:
  727:         if target_id in seen_targets:
  728:             continue
  729:         seen_targets.add(target_id)
  730:         unique_pairs.append((int(source_id), int(target_id)))
  731:     return unique_pairs
  732: 
  733: 
  734: def remap_vocab_matrix(
  735:     source_tensor,
  736:     target_tensor,
  737:     token_pairs: list[tuple[int, int]],
  738:     fallback_source_id: int | None = None,
  739: ):
  740:     remapped = target_tensor.clone()
  741:     source_rows = int(source_tensor.shape[0])
  742:     target_rows = int(target_tensor.shape[0])
  743:     copied_targets: set[int] = set()
  744: 
  745:     if fallback_source_id is not None and 0 <= int(fallback_source_id) < source_rows and target_rows > 0:
  746:         fallback_row = source_tensor[int(fallback_source_id)].to(dtype=target_tensor.dtype, device=target_tensor.device)
  747:         remapped[:] = fallback_row
  748: 
  749:     for source_id, target_id in token_pairs:
  750:         if source_id < 0 or target_id < 0:
  751:             continue
  752:         if source_id >= source_rows or target_id >= target_rows:
  753:             continue
  754:         remapped[target_id] = source_tensor[source_id].to(dtype=target_tensor.dtype, device=target_tensor.device)
  755:         copied_targets.add(int(target_id))
  756:     return remapped
  757: 
  758: 
  759: def transfer_position_embedding(source_tensor, target_tensor):
  760:     transferred = target_tensor.clone()
  761:     if len(source_tensor.shape) != 2 or len(target_tensor.shape) != 2:
  762:         return transferred
  763:     if int(source_tensor.shape[1]) != int(target_tensor.shape[1]):
  764:         return transferred
  765: 
  766:     rows_to_copy = min(int(source_tensor.shape[0]), int(target_tensor.shape[0]))
  767:     if rows_to_copy <= 0:
  768:         return transferred
  769:     transferred[:rows_to_copy] = source_tensor[:rows_to_copy].to(
  770:         dtype=target_tensor.dtype,
  771:         device=target_tensor.device,
  772:     )
  773:     return transferred
  774: 
  775: 
  776: def load_stage2_weights(model, init_model_dir: Path, target_tokenizer: ByteTokenizer, torch_module) -> dict[str, object]:
  777:     state_path = init_model_dir / "model.pt"
  778:     if not state_path.exists():
  779:         raise FileNotFoundError(f"Initial model checkpoint not found: {state_path}")
  780: 
  781:     source_state = torch_module.load(state_path, map_location="cpu", weights_only=False)
  782:     source_tokenizer = ByteTokenizer.from_config(load_json(init_model_dir / "tokenizer_config.json"))
  783:     token_pairs = build_token_id_remap(source_tokenizer, target_tokenizer)
  784:     target_state = model.state_dict()
  785:     updated_state = dict(target_state)
  786:     shared_vocab_transfer = None
  787:     source_vocab_tensor = source_state.get("token_embedding.weight")
  788:     if source_vocab_tensor is None:
  789:         source_vocab_tensor = source_state.get("lm_head.weight")
  790:     if (
  791:         source_vocab_tensor is not None
  792:         and "token_embedding.weight" in target_state
  793:         and "lm_head.weight" in target_state
  794:         and len(target_state["token_embedding.weight"].shape) == 2
  795:         and len(source_vocab_tensor.shape) == 2
  796:         and int(target_state["token_embedding.weight"].shape[1]) == int(source_vocab_tensor.shape[1])
  797:     ):
  798:         shared_vocab_transfer = remap_vocab_matrix(
  799:             source_tensor=source_vocab_tensor,
  800:             target_tensor=target_state["token_embedding.weight"],
  801:             token_pairs=token_pairs,
  802:             fallback_source_id=source_tokenizer.unknown_token_id,
  803:         )
  804:         updated_state["token_embedding.weight"] = shared_vocab_transfer
  805:         updated_state["lm_head.weight"] = shared_vocab_transfer
  806:     loaded_names: list[str] = []
  807:     skipped_names: list[str] = []
  808: 
  809:     for name, tensor in source_state.items():
  810:         if name not in target_state:
  811:             skipped_names.append(name)
  812:             continue
  813:         if name in {"token_embedding.weight", "lm_head.weight"}:
  814:             if shared_vocab_transfer is not None and target_state[name].shape == shared_vocab_transfer.shape:
  815:                 loaded_names.append(name)
  816:                 continue
  817:         if target_state[name].shape == tensor.shape:
  818:             updated_state[name] = tensor
  819:             loaded_names.append(name)
  820:             continue
  821:         if name == "position_embedding.weight":
  822:             updated_state[name] = transfer_position_embedding(
  823:                 source_tensor=tensor,
  824:                 target_tensor=target_state[name],
  825:             )
  826:             loaded_names.append(name)
  827:             continue
  828:         skipped_names.append(name)
  829: 
  830:     model.load_state_dict(updated_state)
  831:     return {
  832:         "loaded_count": len(loaded_names),
  833:         "skipped_count": len(skipped_names),
  834:         "loaded_names": loaded_names,
  835:         "skipped_names": skipped_names,
  836:     }
