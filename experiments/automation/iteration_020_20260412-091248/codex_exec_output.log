  434:         self.pad_token_id = int(regular_token_limit if pad_token_id is None else pad_token_id)
  435:         self.bos_token_id = int(regular_token_limit + 1 if bos_token_id is None else bos_token_id)
  436:         self.eos_token_id = int(regular_token_limit + 2 if eos_token_id is None else eos_token_id)
  437:         self.vocab_size = max(regular_token_limit, self.pad_token_id, self.bos_token_id, self.eos_token_id) + 1
  438: 
  439:     @classmethod
  440:     def from_config(cls, payload: dict) -> "ByteTokenizer":
  441:         chars = payload.get("chars")
  442:         if chars:
  443:             return cls(
  444:                 chars=list(chars),
  445:                 pad_token_id=int(payload["pad_token_id"]),
  446:                 bos_token_id=int(payload["bos_token_id"]),
  447:                 eos_token_id=int(payload["eos_token_id"]),
  448:             )
  449:         regular_token_limit = int(payload.get("regular_token_limit", payload.get("vocab_size", 131) - 3))
  450:         chars = [chr(index) for index in range(regular_token_limit)]
  451:         return cls(
  452:             chars=chars,
  453:             pad_token_id=int(payload["pad_token_id"]),
  454:             bos_token_id=int(payload["bos_token_id"]),
  455:             eos_token_id=int(payload["eos_token_id"]),
  456:         )
  457: 
  458:     def encode(self, text: str, add_special_tokens: bool = False) -> list[int]:
  459:         token_ids = [self.char_to_id.get(char, self.unknown_token_id) for char in text]
  460:         if add_special_tokens:
  461:             return [self.bos_token_id] + token_ids + [self.eos_token_id]
  462:         return token_ids
  463: 
  464:     def decode(self, token_ids: list[int]) -> str:
  465:         return "".join(self.id_to_char[token_id] for token_id in token_ids if token_id in self.id_to_char)
  466: 
  467:     def save(self, path: Path) -> None:
  468:         payload = {
  469:             "type": "char_vocab",
  470:             "chars": self.chars,
  471:             "regular_token_limit": self.regular_token_limit,
  472:             "pad_token_id": self.pad_token_id,
  473:             "bos_token_id": self.bos_token_id,
  474:             "eos_token_id": self.eos_token_id,
  475:             "vocab_size": self.vocab_size,
  476:         }
  477:         with path.open("w", encoding="utf-8") as handle:
  478:             json.dump(payload, handle, indent=2, ensure_ascii=True)
  479:             handle.write("\n")
