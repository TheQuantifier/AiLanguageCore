  631: class TrainingStatusWriter:
  632:     def __init__(self, output_dir: Path, config: dict):
  633:         self.output_dir = output_dir
  634:         self.output_dir.mkdir(parents=True, exist_ok=True)
  635:         self.path = self.output_dir / "training_status.json"
  636:         self.state = {
  637:             "status": "initializing",
  638:             "started_at": utc_now_iso(),
  639:             "updated_at": utc_now_iso(),
  640:             "completed_at": None,
  641:             "pid": os.getpid(),
