 1046:     class CausalSelfAttention(nn.Module):
 1047:         def __init__(self, hidden_size: int, num_heads: int, dropout: float):
 1048:             super().__init__()
 1049:             if hidden_size % num_heads != 0:
 1050:                 raise ValueError("hidden_size must be divisible by num_heads")
 1051:             self.hidden_size = hidden_size
 1052:             self.num_heads = num_heads
 1053:             self.head_dim = hidden_size // num_heads
 1054:             self.qkv = nn.Linear(hidden_size, hidden_size * 3)
 1055:             self.proj = nn.Linear(hidden_size, hidden_size)
 1056:             self.dropout = nn.Dropout(dropout)
 1057: 
 1058:         def forward(self, x):
 1059:             batch_size, seq_len, hidden_size = x.shape
 1060:             qkv = self.qkv(x)
 1061:             q, k, v = qkv.chunk(3, dim=-1)
 1062:             q = q.view(batch_size, seq_len, self.num_heads, self.head_dim).transpose(1, 2)
 1063:             k = k.view(batch_size, seq_len, self.num_heads, self.head_dim).transpose(1, 2)
 1064:             v = v.view(batch_size, seq_len, self.num_heads, self.head_dim).transpose(1, 2)
 1065:             dropout_p = self.dropout.p if self.training else 0.0
 1066:             attn = F.scaled_dot_product_attention(q, k, v, is_causal=True, dropout_p=dropout_p)
 1067:             attn = attn.transpose(1, 2).contiguous().view(batch_size, seq_len, hidden_size)
 1068:             return self.proj(attn)
 1069: 
 1070:     class Block(nn.Module):
 1071:         def __init__(self, hidden_size: int, num_heads: int, mlp_ratio: float, dropout: float):
 1072:             super().__init__()
 1073:             mlp_hidden = int(hidden_size * mlp_ratio)
 1074:             self.norm_1 = nn.LayerNorm(hidden_size)
 1075:             self.attn = CausalSelfAttention(hidden_size, num_heads, dropout)
 1076:             self.norm_2 = nn.LayerNorm(hidden_size)
 1077:             self.mlp = nn.Sequential(
