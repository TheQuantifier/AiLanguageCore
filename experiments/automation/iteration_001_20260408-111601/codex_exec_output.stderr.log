    if current > 1:
        sys.stdout.write("\r")
        sys.stdout.write("\x1b[1A")
        sys.stdout.write("\r" + (" " * clear_width))
        sys.stdout.write("\n")
        sys.stdout.write((" " * clear_width))
        sys.stdout.write("\x1b[1A")
        sys.stdout.write("\r")
    sys.stdout.write(progress_line.ljust(clear_width))
    sys.stdout.write("\n")
