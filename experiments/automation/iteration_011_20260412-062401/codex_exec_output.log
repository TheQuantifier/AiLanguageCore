   78: function Test-AutotrainSafety {
   79:     param(
   80:         [object]$Snapshot,
   81:         [double]$RequiredFreeMemoryGb,
   82:         [double]$RequiredFreeDiskGb,
   83:         [bool]$ShouldStopOnBattery,
   84:         [int]$RequiredBatteryPercent
   85:     )
   86: 
   87:     $issues = @()
   88:     if ($Snapshot.FreeMemoryGb -lt $RequiredFreeMemoryGb) {
   89:         $issues += ("free RAM {0:N2} GB < required {1:N2} GB" -f $Snapshot.FreeMemoryGb, $RequiredFreeMemoryGb)
   90:     }
   91:     if ($Snapshot.FreeDiskGb -lt $RequiredFreeDiskGb) {
   92:         $issues += ("free disk ({0}:) {1:N2} GB < required {2:N2} GB" -f $Snapshot.DriveName, $Snapshot.FreeDiskGb, $RequiredFreeDiskGb)
   93:     }
   94:     if ($ShouldStopOnBattery -and $Snapshot.HasBattery -and $Snapshot.OnBattery) {
   95:         $issues += 'running on battery power'
   96:     }
   97:     if ($ShouldStopOnBattery -and $Snapshot.HasBattery -and $null -ne $Snapshot.BatteryPercent -and $Snapshot.BatteryPercent -lt $RequiredBatteryPercent) {
   98:         $issues += ("battery {0}% < required {1}%" -f $Snapshot.BatteryPercent, $RequiredBatteryPercent)
   99:     }
  100: 
  101:     return [pscustomobject]@{
  102:         IsSafe = ($issues.Count -eq 0)
  103:         Issues = $issues
  104:     }
  105: }
