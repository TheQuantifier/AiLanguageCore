  170:         run_date, run_time = split_run_timestamp(run_name)
  171:         report_path = None
  172:         report_path_value = status.get("benchmark_report")
  173:         if isinstance(report_path_value, str) and report_path_value.strip():
  174:             candidate = Path(report_path_value)
  175:             if candidate.exists():
  176:                 report_path = candidate
  177:             else:
  178:                 relative_candidate = Path(report_path_value)
  179:                 if relative_candidate.exists():
