  191:             if report_type not in {"unknown", "custom"}:
  192:                 training_type = report_type
  193:         if training_type in {"unknown", "custom"}:
  194:             training_type = infer_type_from_run_name(run_name)
  195: 
  196:         training_category = report.get("training_category")
  197:         if not isinstance(training_category, str) or not training_category.strip():
  198:             training_category = infer_category_from_benchmark_path(status.get("benchmark_file"))
  199: 
  200:         rows.append(
  201:             {
