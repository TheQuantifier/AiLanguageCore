  246:     ]
  247:     targets = [path, path.with_name(f"{path.stem}.latest{path.suffix}")]
  248:     last_error = None
  249:     for target in targets:
  250:         try:
  251:             with target.open("w", encoding="utf-8", newline="") as handle:
  252:                 writer = csv.DictWriter(handle, fieldnames=fieldnames)
  253:                 writer.writeheader()
