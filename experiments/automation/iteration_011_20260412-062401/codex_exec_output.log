  146: def split_run_timestamp(run_name: str) -> tuple[str, str]:
  147:     parts = run_name.rsplit("-", 2)
  148:     if len(parts) == 3:
  149:         date_part, time_part = parts[1], parts[2]
  150:         if len(date_part) == 8 and len(time_part) == 6 and date_part.isdigit() and time_part.isdigit():
  151:             return (
  152:                 f"{date_part[0:4]}-{date_part[4:6]}-{date_part[6:8]}",
  153:                 f"{time_part[0:2]}:{time_part[2:4]}:{time_part[4:6]}",
  154:             )
  155:     return "", ""
