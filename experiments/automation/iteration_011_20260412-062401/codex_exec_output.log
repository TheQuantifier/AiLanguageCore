  181:         if report_path is None:
  182:             candidate = reports_dir / f"benchmark_report-{run_name}.json"
  183:             if candidate.exists():
  184:                 report_path = candidate
  185:         report = load_json(report_path) if report_path and report_path.exists() else {}
  186:         training_type = report.get("training_type")
  187:         if not isinstance(training_type, str) or not training_type.strip():
  188:             training_type = infer_type_from_benchmark_path(status.get("benchmark_file"))
  189:         if training_type in {"unknown", "custom"}:
