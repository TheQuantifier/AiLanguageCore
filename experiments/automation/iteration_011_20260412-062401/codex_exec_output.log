   28: function Get-AutotrainSafetySnapshot {
   29:     param(
   30:         [string]$RepoRoot
   31:     )
   32: 
   33:     $resolvedRoot = (Resolve-Path $RepoRoot).Path
   34:     $os = Get-CimInstance -ClassName Win32_OperatingSystem
   35:     $freeMemoryGb = [double]$os.FreePhysicalMemory / 1MB
   36:     $totalMemoryGb = [double]$os.TotalVisibleMemorySize / 1MB
   37: 
   38:     $driveRoot = [System.IO.Path]::GetPathRoot($resolvedRoot)
   39:     $driveName = $driveRoot.Substring(0, 1)
   40:     $drive = Get-PSDrive -Name $driveName
   41:     $freeDiskGb = [double]$drive.Free / 1GB
   42: 
   43:     $battery = $null
   44:     try {
   45:         $battery = Get-CimInstance -ClassName Win32_Battery -ErrorAction Stop | Select-Object -First 1
   46:     } catch {
   47:         $battery = $null
   48:     }
   49: 
   50:     $hasBattery = $null -ne $battery
   51:     $batteryPercent = $null
   52:     $batteryStatus = $null
   53:     $onBattery = $false
   54:     if ($hasBattery) {
   55:         if ($null -ne $battery.EstimatedChargeRemaining) {
   56:             $batteryPercent = [int]$battery.EstimatedChargeRemaining
   57:         }
   58:         if ($null -ne $battery.BatteryStatus) {
   59:             $batteryStatus = [int]$battery.BatteryStatus
   60:         }
   61:         if ($batteryStatus -in @(1, 4, 5, 11)) {
   62:             $onBattery = $true
   63:         }
   64:     }
   65: 
   66:     return [pscustomobject]@{
   67:         FreeMemoryGb = $freeMemoryGb
   68:         TotalMemoryGb = $totalMemoryGb
   69:         FreeDiskGb = $freeDiskGb
   70:         DriveName = $driveName
   71:         HasBattery = $hasBattery
   72:         BatteryPercent = $batteryPercent
   73:         BatteryStatus = $batteryStatus
   74:         OnBattery = $onBattery
   75:     }
   76: }
