import json
from collections import defaultdict
from pathlib import Path

path = Path('data/processed/train_sft.jsonl')
by_prompt = defaultdict(set)
raw = defaultdict(list)
for line in path.read_text(encoding='utf-8').splitlines():
    if not line.strip():
        continue
    row = json.loads(line)
    msgs = row['messages']
    user = msgs[1]['content'].strip().lower()
    label = msgs[2]['content'].strip()
    by_prompt[user].add(label)
    raw[user].append((row['id'], label, msgs[1]['content']))

conflicts = {k:v for k,v in by_prompt.items() if len(v)>1}
print('conflict_count', len(conflicts))
for i,(k,labels) in enumerate(sorted(conflicts.items())[:40],1):
    print('\\nPROMPT:', raw[k][0][2])
    print('LABELS:', sorted(labels))
    for rec in raw[k]:
        print(' ', rec[0], rec[1])
