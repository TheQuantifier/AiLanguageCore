import json,re
from pathlib import Path
from collections import defaultdict
seed = json.loads(Path('data/raw/v1_seed_dataset.json').read_text(encoding='utf-8'))
gen = json.loads(Path('data/raw/generated_dataset.json').read_text(encoding='utf-8'))
patterns = [
    re.compile(r\"\\s+for me\\b\", re.I),
    re.compile(r\"\\s+right now\\b\", re.I),
    re.compile(r\"\\s+in my situation\\b\", re.I),
    re.compile(r\"\\s*i am not sure\\b\", re.I),
]
def norm(text):
    key = re.sub(r\"\\s+\", \" \", text.strip()).lower()
    for p in patterns:
        key = p.sub('', key)
    key = re.sub(r\"[?."'!,]", '"'', key)
    key = re.sub(r\"\\s+\", \" \", key).strip()
    return key
by_key=defaultdict(list)
for source, items in [('seed',seed),('generated',gen)]:
    for item in items:
        by_key[norm(item['user_input'])].append((source,item['response_type'],item['user_input']))
for key,vals in by_key.items():
    types={v[1] for v in vals}
    if len(vals)>=2 and 'CLARIFICATION' in types:
        print('\\nKEY', key)
        for v in vals[:10]:
            print(v)
