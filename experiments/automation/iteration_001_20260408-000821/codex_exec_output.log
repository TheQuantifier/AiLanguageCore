from collections import Counter
from pathlib import Path
report = json.loads(Path('experiments/benchmark_report-v1-native-byte-transformer-20260408-000823.json').read_text())
conf = Counter()
for r in report['results']:
    exp = r['expected_response_type']
    pred = r['predicted_response_type'] or 'INVALID'
    if exp "'!= pred:
        conf[(exp,pred)] += 1
print(conf)
