  551: 
  552: def build_token_id_remap(source_tokenizer: ByteTokenizer, target_tokenizer: ByteTokenizer) -> list[tuple[int, int]]:
  553:     pairs: list[tuple[int, int]] = []
  554: 
  555:     for char, source_id in source_tokenizer.char_to_id.items():
  556:         target_id = target_tokenizer.char_to_id.get(char)
  557:         if target_id is not None:
  558:             pairs.append((source_id, target_id))
  559: 
  560:     special_pairs = [
  561:         (source_tokenizer.pad_token_id, target_tokenizer.pad_token_id),
  562:         (source_tokenizer.bos_token_id, target_tokenizer.bos_token_id),
  563:         (source_tokenizer.eos_token_id, target_tokenizer.eos_token_id),
  564:     ]
  565:     for source_id, target_id in special_pairs:
  566:         pairs.append((int(source_id), int(target_id)))
  567: 
  568:     unique_pairs: list[tuple[int, int]] = []
  569:     seen_targets: set[int] = set()
  570:     for source_id, target_id in pairs:
  571:         if target_id in seen_targets:
  572:             continue
  573:         seen_targets.add(target_id)
  574:         unique_pairs.append((int(source_id), int(target_id)))
  575:     return unique_pairs
  576: 
  577: 
  578: def remap_vocab_matrix(
  579:     source_tensor,
  580:     target_tensor,
  581:     token_pairs: list[tuple[int, int]],
  582: ):
  583:     remapped = target_tensor.clone()
  584:     source_rows = int(source_tensor.shape[0])
  585:     target_rows = int(target_tensor.shape[0])
  586:     for source_id, target_id in token_pairs:
  587:         if source_id < 0 or target_id < 0:
  588:             continue
  589:         if source_id >= source_rows or target_id >= target_rows:
  590:             continue
  591:         remapped[target_id] = source_tensor[source_id].to(dtype=target_tensor.dtype, device=target_tensor.device)
  592:     return remapped
  593: 
  594: 
  595: def transfer_position_embedding(source_tensor, target_tensor):
  596:     transferred = target_tensor.clone()
  597:     if len(source_tensor.shape) != 2 or len(target_tensor.shape) != 2:
  598:         return transferred
  599:     if int(source_tensor.shape[1]) != int(target_tensor.shape[1]):
  600:         return transferred
  601: 
  602:     rows_to_copy = min(int(source_tensor.shape[0]), int(target_tensor.shape[0]))
  603:     if rows_to_copy <= 0:
  604:         return transferred
  605:     transferred[:rows_to_copy] = source_tensor[:rows_to_copy].to(
  606:         dtype=target_tensor.dtype,
  607:         device=target_tensor.device,
  608:     )
  609:     return transferred
  610: 
  611: 
  612: def load_stage2_weights(model, init_model_dir: Path, target_tokenizer: ByteTokenizer, torch_module) -> dict[str, object]:
  613:     state_path = init_model_dir / "model.pt"
  614:     if not state_path.exists():
  615:         raise FileNotFoundError(f"Initial model checkpoint not found: {state_path}")
  616: 
  617:     source_state = torch_module.load(state_path, map_location="cpu", weights_only=False)
  618:     source_tokenizer = ByteTokenizer.from_config(load_json(init_model_dir / "tokenizer_config.json"))
  619:     token_pairs = build_token_id_remap(source_tokenizer, target_tokenizer)
  620:     target_state = model.state_dict()
  621:     updated_state = dict(target_state)
  622:     loaded_names: list[str] = []
  623:     skipped_names: list[str] = []
  624: 
  625:     for name, tensor in source_state.items():
  626:         if name not in target_state:
  627:             skipped_names.append(name)
  628:             continue
  629:         if target_state[name].shape == tensor.shape:
  630:             updated_state[name] = tensor
  631:             loaded_names.append(name)
  632:             continue
  633:         if name in {"token_embedding.weight", "lm_head.weight"}:
  634:             if len(target_state[name].shape) == 2 and len(tensor.shape) == 2 and int(target_state[name].shape[1]) == int(tensor.shape[1]):
  635:                 updated_state[name] = remap_vocab_matrix(
  636:                     source_tensor=tensor,
  637:                     target_tensor=target_state[name],
  638:                     token_pairs=token_pairs,
  639:                 )
  640:                 loaded_names.append(name)
  641:                 continue
  642:         if name == "position_embedding.weight":
  643:             updated_state[name] = transfer_position_embedding(
  644:                 source_tensor=tensor,
  645:                 target_tensor=target_state[name],
  646:             )
  647:             loaded_names.append(name)
  648:             continue
  649:         skipped_names.append(name)
  650: 
  651:     model.load_state_dict(updated_state)
  652:     return {
  653:         "loaded_count": len(loaded_names),
  654:         "skipped_count": len(skipped_names),
  655:         "loaded_names": loaded_names,
  656:         "skipped_names": skipped_names,
  657:     }
