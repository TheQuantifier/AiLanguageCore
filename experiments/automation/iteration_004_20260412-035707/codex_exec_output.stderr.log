  659: 
  660: class DirectMLAdamW:
  661:     def __init__(
  662:         self,
  663:         torch_module,
  664:         params,
  665:         lr: float,
  666:         weight_decay: float = 0.01,
  667:         betas: tuple[float, float] = (0.9, 0.999),
  668:         eps: float = 1e-8,
  669:     ) -> None:
  670:         self.torch = torch_module
  671:         self.params = [param for param in params if param.requires_grad]
  672:         self.lr = float(lr)
  673:         self.weight_decay = float(weight_decay)
  674:         self.beta1 = float(betas[0])
  675:         self.beta2 = float(betas[1])
  676:         self.eps = float(eps)
  677:         self.step_count = 0
  678:         self.state: dict[int, dict[str, object]] = {}
  679: 
  680:     def zero_grad(self, set_to_none: bool = True) -> None:
  681:         for param in self.params:
  682:             if param.grad is None:
  683:                 continue
  684:             if set_to_none:
  685:                 param.grad = None
  686:             else:
  687:                 param.grad.zero_()
  688: 
  689:     def step(self) -> None:
  690:         self.step_count += 1
  691:         bias_correction1 = 1.0 - (self.beta1 ** self.step_count)
  692:         bias_correction2 = 1.0 - (self.beta2 ** self.step_count)
  693: 
  694:         with self.torch.no_grad():
  695:             for param in self.params:
  696:                 grad = param.grad
  697:                 if grad is None:
  698:                     continue
  699:                 if grad.is_sparse:
  700:                     raise RuntimeError("DirectMLAdamW does not support sparse gradients.")
  701: 
  702:                 state = self.state.get(id(param))
  703:                 if state is None:
  704:                     state = {
  705:                         "exp_avg": self.torch.zeros_like(param),
  706:                         "exp_avg_sq": self.torch.zeros_like(param),
  707:                     }
  708:                     self.state[id(param)] = state
  709: 
  710:                 exp_avg = state["exp_avg"]
  711:                 exp_avg_sq = state["exp_avg_sq"]
  712: 
  713:                 exp_avg.mul_(self.beta1).add_(grad, alpha=(1.0 - self.beta1))
  714:                 exp_avg_sq.mul_(self.beta2).addcmul_(grad, grad, value=(1.0 - self.beta2))
  715: 
  716:                 denom = exp_avg_sq.sqrt() / math.sqrt(bias_correction2)
  717:                 denom.add_(self.eps)
  718:                 step_size = self.lr / bias_correction1
  719: 
  720:                 if self.weight_decay != 0.0:
  721:                     param.add_(param, alpha=(-self.lr * self.weight_decay))
  722:                 param.addcdiv_(exp_avg, denom, value=-step_size)
  723: 
  724: 
  725: def create_optimizer(torch_module, model, config: dict, device_label: str):
  726:     optimizer_name = str(config.get("optimizer", "auto")).strip().lower()
  727:     lr = float(config["learning_rate"])
  728:     weight_decay = float(config.get("weight_decay", 0.01))
  729:     betas = tuple(config.get("adam_betas", [0.9, 0.999]))
  730:     eps = float(config.get("adam_eps", 1e-8))
  731: 
  732:     if optimizer_name == "auto":
  733:         optimizer_name = "adamw"
  734: 
  735:     if optimizer_name == "adamw_dml_safe":
  736:         optimizer = DirectMLAdamW(
  737:             torch_module,
  738:             model.parameters(),
  739:             lr=lr,
  740:             weight_decay=weight_decay,
  741:             betas=(float(betas[0]), float(betas[1])),
  742:             eps=eps,
  743:         )
  744:         return optimizer, "adamw_dml_safe"
  745: 
  746:     if optimizer_name == "adamw":
  747:         optimizer = torch_module.optim.AdamW(
  748:             model.parameters(),
  749:             lr=lr,
  750:             weight_decay=weight_decay,
  751:             foreach=False,
  752:         )
  753:         return optimizer, "adamw"
  754: 
  755:     raise ValueError("Unsupported optimizer. Expected one of: auto, adamw, adamw_dml_safe.")
