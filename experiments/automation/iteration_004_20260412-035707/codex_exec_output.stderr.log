  850:     class CausalSelfAttention(nn.Module):
  851:         def __init__(self, hidden_size: int, num_heads: int, dropout: float):
  852:             super().__init__()
  853:             if hidden_size % num_heads != 0:
  854:                 raise ValueError("hidden_size must be divisible by num_heads")
  855:             self.hidden_size = hidden_size
  856:             self.num_heads = num_heads
  857:             self.head_dim = hidden_size // num_heads
  858:             self.qkv = nn.Linear(hidden_size, hidden_size * 3)
  859:             self.proj = nn.Linear(hidden_size, hidden_size)
  860:             self.dropout = nn.Dropout(dropout)
  861: 
  862:         def forward(self, x):
  863:             batch_size, seq_len, hidden_size = x.shape
  864:             qkv = self.qkv(x)
  865:             q, k, v = qkv.chunk(3, dim=-1)
  866:             q = q.view(batch_size, seq_len, self.num_heads, self.head_dim).transpose(1, 2)
  867:             k = k.view(batch_size, seq_len, self.num_heads, self.head_dim).transpose(1, 2)
  868:             v = v.view(batch_size, seq_len, self.num_heads, self.head_dim).transpose(1, 2)
  869:             dropout_p = self.dropout.p if self.training else 0.0
  870:             attn = F.scaled_dot_product_attention(q, k, v, is_causal=True, dropout_p=dropout_p)
  871:             attn = attn.transpose(1, 2).contiguous().view(batch_size, seq_len, hidden_size)
  872:             return self.proj(attn)
  873: 
  874:     class Block(nn.Module):
  875:         def __init__(self, hidden_size: int, num_heads: int, mlp_ratio: float, dropout: float):
  876:             super().__init__()
  877:             mlp_hidden = int(hidden_size * mlp_ratio)
  878:             self.norm_1 = nn.LayerNorm(hidden_size)
  879:             self.attn = CausalSelfAttention(hidden_size, num_heads, dropout)
  880:             self.norm_2 = nn.LayerNorm(hidden_size)
  881:             self.mlp = nn.Sequential(
  882:                 nn.Linear(hidden_size, mlp_hidden),
  883:                 nn.GELU(),
  884:                 nn.Linear(mlp_hidden, hidden_size),
  885:                 nn.Dropout(dropout),
  886:             )
  887: 
  888:         def forward(self, x):
  889:             x = x + self.attn(self.norm_1(x))
  890:             x = x + self.mlp(self.norm_2(x))
  891:             return x
