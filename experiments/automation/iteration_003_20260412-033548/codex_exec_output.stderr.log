  758: def render_progress_bar(current: int, total: int, width: int = 30) -> str:
  759:     if total <= 0:
  760:         total = 1
  761:     ratio = max(0.0, min(1.0, current / total))
  762:     filled = int(width * ratio)
  763:     if filled >= width:
  764:         bar = "=" * width
  765:     elif filled <= 0:
  766:         bar = "-" * width
  767:     else:
  768:         bar = ("=" * max(0, filled - 1)) + ">" + ("-" * (width - filled))
  769:     percent = ratio * 100.0
  770:     return f"[{bar}] {current}/{total} steps ({percent:5.1f}%)"
  771: 
  772: 
  773: def format_duration(seconds: float) -> str:
  774:     total_seconds = max(0, int(seconds))
  775:     hours, remainder = divmod(total_seconds, 3600)
  776:     minutes, secs = divmod(remainder, 60)
  777:     return f"{hours:02d}:{minutes:02d}:{secs:02d}"
  778: 
  779: 
  780: def print_progress_block(
  781:     current: int,
  782:     total: int,
  783:     epoch: float,
  784:     epoch_index: int,
  785:     total_epochs: int,
  786:     batch_in_epoch: int,
  787:     batches_per_epoch: int,
  788:     elapsed_seconds: float,
  789:     steps_per_second: float,
  790:     train_loss: float | None = None,
  791:     validation_loss: float | None = None,
  792: ) -> None:
  793:     parts = [render_progress_bar(current, total)]
  794:     details = [
  795:         f"epoch={epoch_index}/{total_epochs} ({epoch:.2f})",
  796:         f"batch={batch_in_epoch}/{batches_per_epoch}",
  797:         f"elapsed={format_duration(elapsed_seconds)}",
  798:         f"steps_per_sec={steps_per_second:.3f}",
  799:     ]
  800:     if train_loss is not None:
  801:         details.append(f"train_loss={train_loss:.4f}")
  802:     if validation_loss is not None:
  803:         details.append(f"val_loss={validation_loss:.4f}")
  804:     progress_line = " | ".join(parts)
  805:     details_line = " | ".join(details)
  806:     clear_width = max(len(progress_line), len(details_line), 120)
  807:     if current > 1:
  808:         sys.stdout.write("\r")
  809:         sys.stdout.write("\x1b[1A")
  810:         sys.stdout.write("\r" + (" " * clear_width))
  811:         sys.stdout.write("\n")
  812:         sys.stdout.write((" " * clear_width))
  813:         sys.stdout.write("\x1b[1A")
  814:         sys.stdout.write("\r")
  815:     sys.stdout.write(progress_line.ljust(clear_width))
  816:     sys.stdout.write("\n")
  817:     sys.stdout.write(details_line.ljust(clear_width))
  818:     sys.stdout.flush()
