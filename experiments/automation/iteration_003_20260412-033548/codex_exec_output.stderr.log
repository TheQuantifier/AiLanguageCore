  106: 
  107: function Wait-ForAutotrainSafeResources {
  108:     param(
  109:         [string]$RepoRoot,
  110:         [double]$RequiredFreeMemoryGb,
  111:         [double]$RequiredFreeDiskGb,
  112:         [bool]$ShouldStopOnBattery,
  113:         [int]$RequiredBatteryPercent,
  114:         [int]$PollIntervalSeconds,
  115:         [int]$MaxWaitMinutes
  116:     )
  117: 
  118:     $deadline = (Get-Date).AddMinutes($MaxWaitMinutes)
  119:     while ($true) {
  120:         $snapshot = Get-AutotrainSafetySnapshot -RepoRoot $RepoRoot
  121:         $safety = Test-AutotrainSafety `
  122:             -Snapshot $snapshot `
  123:             -RequiredFreeMemoryGb $RequiredFreeMemoryGb `
  124:             -RequiredFreeDiskGb $RequiredFreeDiskGb `
  125:             -ShouldStopOnBattery $ShouldStopOnBattery `
  126:             -RequiredBatteryPercent $RequiredBatteryPercent
  127: 
  128:         if ($safety.IsSafe) {
  129:             Write-Host ("Safety check passed | free_ram={0:N2}GB/{1:N2}GB | free_disk={2:N2}GB | on_battery={3}" -f $snapshot.FreeMemoryGb, $snapshot.TotalMemoryGb, $snapshot.FreeDiskGb, $snapshot.OnBattery)
  130:             return $snapshot
  131:         }
  132: 
  133:         $remaining = [int][Math]::Ceiling(($deadline - (Get-Date)).TotalSeconds)
  134:         if ($remaining -le 0) {
  135:             $issueText = $safety.Issues -join '; '
  136:             throw "Safety guard timeout after $MaxWaitMinutes minute(s): $issueText"
  137:         }
  138:         Write-Warning ("Safety guard waiting ({0}s left): {1}" -f $remaining, ($safety.Issues -join '; '))
  139:         Start-Sleep -Seconds ([Math]::Max(1, $PollIntervalSeconds))
  140:     }
  141: }
