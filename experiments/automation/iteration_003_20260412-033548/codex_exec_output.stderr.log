  235: def resolve_init_model_path(path_value: str | Path | None, repo_root: Path) -> Path | None:
  236:     if not path_value:
  237:         return None
  238:     value = str(path_value).strip()
  239:     if not value:
  240:         return None
  241:     if value.startswith("latest:"):
  242:         parts = value.split(":")
  243:         try:
