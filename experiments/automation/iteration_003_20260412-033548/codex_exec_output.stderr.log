  143: function Acquire-AutotrainLock {
  144:     param(
  145:         [string]$LockPath
  146:     )
  147: 
  148:     try {
  149:         $stream = [System.IO.File]::Open($LockPath, [System.IO.FileMode]::OpenOrCreate, [System.IO.FileAccess]::ReadWrite, [System.IO.FileShare]::None)
  150:     } catch {
  151:         throw "Another autotrain process appears to be running (lock held at $LockPath). Stop the other process or remove stale lock after confirming no active run."
  152:     }
  153: 
  154:     $payload = "pid=$PID`nstarted_at=$((Get-Date).ToString('yyyy-MM-dd HH:mm:ss'))`n"
  155:     $bytes = [System.Text.Encoding]::UTF8.GetBytes($payload)
  156:     $stream.SetLength(0)
  157:     $stream.Write($bytes, 0, $bytes.Length)
  158:     $stream.Flush()
  159:     return $stream
  160: }
  161: 
  162: function Release-AutotrainLock {
  163:     param(
  164:         $LockHandle,
  165:         [string]$LockPath
  166:     )
  167: 
  168:     if ($LockHandle) {
  169:         try {
  170:             $LockHandle.Dispose()
  171:         } catch {
  172:             Write-Warning "Failed to release autotrain lock handle: $($_.Exception.Message)"
  173:         }
  174:     }
  175: 
  176:     if (Test-Path $LockPath) {
  177:         Remove-Item -LiteralPath $LockPath -Force -ErrorAction SilentlyContinue
  178:     }
  179: }
