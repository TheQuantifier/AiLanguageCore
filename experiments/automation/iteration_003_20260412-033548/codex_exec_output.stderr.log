  267: class ByteTokenizer:
  268:     def __init__(
  269:         self,
  270:         chars: list[str],
  271:         pad_token_id: int | None = None,
  272:         bos_token_id: int | None = None,
  273:         eos_token_id: int | None = None,
  274:     ):
  275:         ordered_chars = []
  276:         seen = set()
  277:         for char in chars:
  278:             if len(char) != 1:
  279:                 continue
  280:             if char in seen:
  281:                 continue
  282:             ordered_chars.append(char)
  283:             seen.add(char)
  284:         if "?" not in seen:
  285:             ordered_chars.append("?")
  286:             seen.add("?")
  287:         self.chars = ordered_chars
  288:         self.char_to_id = {char: index for index, char in enumerate(self.chars)}
  289:         self.id_to_char = {index: char for char, index in self.char_to_id.items()}
  290:         self.unknown_token_id = self.char_to_id["?"]
  291:         regular_token_limit = len(self.chars)
  292:         self.regular_token_limit = regular_token_limit
  293:         self.pad_token_id = int(regular_token_limit if pad_token_id is None else pad_token_id)
  294:         self.bos_token_id = int(regular_token_limit + 1 if bos_token_id is None else bos_token_id)
  295:         self.eos_token_id = int(regular_token_limit + 2 if eos_token_id is None else eos_token_id)
  296:         self.vocab_size = max(regular_token_limit, self.pad_token_id, self.bos_token_id, self.eos_token_id) + 1
  297: 
  298:     @classmethod
  299:     def from_config(cls, payload: dict) -> "ByteTokenizer":
  300:         chars = payload.get("chars")
