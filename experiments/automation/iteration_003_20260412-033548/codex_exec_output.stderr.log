  254: def render_messages(messages: list[dict], add_generation_prompt: bool) -> str:
  255:     parts = []
  256:     for message in messages:
  257:         role = message["role"]
  258:         prefix = ROLE_PREFIXES[role]
  259:         parts.append(prefix)
  260:         parts.append(message["content"])
  261:         parts.append("\n")
  262:     if add_generation_prompt:
  263:         parts.append(ROLE_PREFIXES["assistant"])
  264:     return "".join(parts)
