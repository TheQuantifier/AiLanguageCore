  313:             bos_token_id=int(payload["bos_token_id"]),
  314:             eos_token_id=int(payload["eos_token_id"]),
  315:         )
  316: 
  317:     def encode(self, text: str, add_special_tokens: bool = False) -> list[int]:
  318:         token_ids = [self.char_to_id.get(char, self.unknown_token_id) for char in text]
  319:         if add_special_tokens:
  320:             return [self.bos_token_id] + token_ids + [self.eos_token_id]

