  245:                 return find_latest_completed_run(repo_root, None, parts[1])
  246:             if len(parts) == 3:
  247:                 return find_latest_completed_run(repo_root, parts[1], parts[2])
  248:         except FileNotFoundError:
  249:             return None
  250:         raise ValueError("init_from_model_path must use latest:<category> or latest:<type>:<category>")
  251:     return resolve_path(value, repo_root)
