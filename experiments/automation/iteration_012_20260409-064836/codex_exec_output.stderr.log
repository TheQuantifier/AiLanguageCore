def run_post_training_benchmark(repo_root: Path, output_dir: Path) -> Path:
    report_path = repo_root / "experiments" / f"benchmark_report-{output_dir.name}.json"
    status_path = output_dir / "benchmark_status.json"
    command = [
        os.sys.executable,
