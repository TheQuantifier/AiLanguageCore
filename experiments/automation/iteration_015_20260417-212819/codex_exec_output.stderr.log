247:def parse_iso_timestamp(value: object) -> float | None:
248:    if not isinstance(value, str):
249:        return None
250:    text = value.strip()
251:    if not text:
252:        return None
253:    if text.endswith("Z"):
254:        text = f"{text[:-1]}+00:00"
255:    try:
256:        return datetime.fromisoformat(text).timestamp()
257:    except ValueError:
