        if "rx " in cleaned or cleaned.endswith(" rx") or "radeon rx" in cleaned:
            score += 20
        if "graphics" in cleaned and "rx" not in cleaned and "rtx" not in cleaned:
            score -= 25
        if "intel" in cleaned:
