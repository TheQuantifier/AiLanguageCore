  628: 
  629:     counts: dict[str, int] = {}
  630:     for example in examples:
  631:         counts[example.response_type] = counts.get(example.response_type, 0) + 1
  632: 
  633:     if not counts:
  634:         return {}
  635: 
  636:     total_examples = len(examples)
  637:     total_classes = len(counts)
  638:     normalized_weights = {
  639:         response_type: ((total_examples / (total_classes * count)) ** weight_power)
  640:         for response_type, count in counts.items()
  641:     }
  642:     mean_weight = sum(normalized_weights.values()) / len(normalized_weights)
  643:     if mean_weight <= 0:
  644:         return {}
  645:     return {
