  991: def render_progress_bar(current: int, total: int, width: int = 30) -> str:
  992:     if total <= 0:
  993:         total = 1
  994:     ratio = max(0.0, min(1.0, current / total))
  995:     filled = int(width * ratio)
  996:     if filled >= width:
  997:         bar = "=" * width
  998:     elif filled <= 0:
  999:         bar = "-" * width
 1000:     else:
 1001:         bar = ("=" * max(0, filled - 1)) + ">" + ("-" * (width - filled))
 1002:     percent = ratio * 100.0
 1003:     return f"[{bar}] {current}/{total} steps ({percent:5.1f}%)"
