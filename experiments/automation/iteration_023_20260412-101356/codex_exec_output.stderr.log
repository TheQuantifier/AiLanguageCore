  762: def build_token_id_remap(source_tokenizer: ByteTokenizer, target_tokenizer: ByteTokenizer) -> list[tuple[int, int]]:
  763:     pairs: list[tuple[int, int]] = []
  764: 
  765:     for char, source_id in source_tokenizer.char_to_id.items():
  766:         target_id = target_tokenizer.char_to_id.get(char)
  767:         if target_id is not None:
  768:             pairs.append((source_id, target_id))
  769: 
  770:     special_pairs = [
  771:         (source_tokenizer.pad_token_id, target_tokenizer.pad_token_id),
  772:         (source_tokenizer.bos_token_id, target_tokenizer.bos_token_id),
  773:         (source_tokenizer.eos_token_id, target_tokenizer.eos_token_id),
  774:     ]
  775:     for source_id, target_id in special_pairs:
  776:         pairs.append((int(source_id), int(target_id)))
  777: 
  778:     unique_pairs: list[tuple[int, int]] = []
  779:     seen_targets: set[int] = set()
  780:     for source_id, target_id in pairs:
  781:         if target_id in seen_targets:
  782:             continue
  783:         seen_targets.add(target_id)
  784:         unique_pairs.append((int(source_id), int(target_id)))
  785:     return unique_pairs
