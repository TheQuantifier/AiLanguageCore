  813: def transfer_position_embedding(source_tensor, target_tensor):
  814:     transferred = target_tensor.clone()
  815:     if len(source_tensor.shape) != 2 or len(target_tensor.shape) != 2:
  816:         return transferred
  817:     if int(source_tensor.shape[1]) != int(target_tensor.shape[1]):
  818:         return transferred
  819: 
  820:     rows_to_copy = min(int(source_tensor.shape[0]), int(target_tensor.shape[0]))
  821:     if rows_to_copy <= 0:
  822:         return transferred
  823:     transferred[:rows_to_copy] = source_tensor[:rows_to_copy].to(
  824:         dtype=target_tensor.dtype,
  825:         device=target_tensor.device,
  826:     )
  827:     return transferred
