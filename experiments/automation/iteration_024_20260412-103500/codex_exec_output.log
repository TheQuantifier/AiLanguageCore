  543: def fit_prompt_and_answer(prompt_ids: list[int], answer_ids: list[int], max_seq_length: int) -> tuple[list[int], list[int]]:
  544:     full_input_ids = prompt_ids + answer_ids
  545:     full_label_ids = ([-100] * len(prompt_ids)) + answer_ids
  546:     if len(full_input_ids) <= max_seq_length:
  547:         return full_input_ids, full_label_ids
  548: 
  549:     if len(answer_ids) >= max_seq_length:
  550:         trimmed_answer = answer_ids[-max_seq_length:]
  551:         return trimmed_answer, trimmed_answer[:]
  552: 
  553:     prompt_budget = max_seq_length - len(answer_ids)
  554:     trimmed_prompt = prompt_ids[-prompt_budget:] if prompt_budget > 0 else []
  555:     input_ids = trimmed_prompt + answer_ids
  556:     label_ids = ([-100] * len(trimmed_prompt)) + answer_ids
  557:     return input_ids, label_ids
  558: 
  559: 
  560: def build_examples(rows: list[dict], tokenizer: ByteTokenizer, max_seq_length: int) -> list[Example]:
  561:     examples = []
  562:     for row in rows:
  563:         prompt_text = render_messages(row["messages"][:2], add_generation_prompt=True)
  564:         answer_text = row["messages"][2]["content"]
  565: 
  566:         prompt_ids = [tokenizer.bos_token_id] + tokenizer.encode(prompt_text, add_special_tokens=False)
  567:         answer_ids = tokenizer.encode(answer_text, add_special_tokens=False) + [tokenizer.eos_token_id]
  568:         input_ids, label_ids = fit_prompt_and_answer(prompt_ids, answer_ids, max_seq_length)
  569:         examples.append(
  570:             Example(
  571:                 input_ids=input_ids,
  572:                 label_ids=label_ids,
  573:                 response_type=answer_text,
  574:             )
  575:         )
  576:     return examples
  577: 
