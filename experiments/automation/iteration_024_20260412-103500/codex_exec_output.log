  359: def render_progress_bar(current: int, total: int, width: int = 30) -> str:
  360:     if total <= 0:
  361:         total = 1
  362:     ratio = max(0.0, min(1.0, current / total))
  363:     filled = int(width * ratio)
  364:     if filled >= width:
  365:         bar = "=" * width
  366:     elif filled <= 0:
  367:         bar = "-" * width
  368:     else:
  369:         bar = ("=" * max(0, filled - 1)) + ">" + ("-" * (width - filled))
  370:     return f"[{bar}] {current}/{total} ({ratio * 100:5.1f}%)"
