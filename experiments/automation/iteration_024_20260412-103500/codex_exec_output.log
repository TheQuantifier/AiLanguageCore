  608: def collate_batch(batch: list[Example], tokenizer: ByteTokenizer, torch_module) -> tuple[object, object]:
  609:     max_length = max(len(example.input_ids) for example in batch)
  610:     input_rows = []
  611:     label_rows = []
  612:     for example in batch:
  613:         pad_count = max_length - len(example.input_ids)
  614:         input_rows.append(example.input_ids + ([tokenizer.pad_token_id] * pad_count))
  615:         label_rows.append(example.label_ids + ([-100] * pad_count))
  616:     input_ids = torch_module.tensor(input_rows, dtype=torch_module.long)
  617:     labels = torch_module.tensor(label_rows, dtype=torch_module.long)
  618:     return input_ids, labels
