  651: def compute_batch_loss(
  652:     logits,
  653:     labels,
  654:     batch: list[Example],
  655:     vocab_size: int,
  656:     class_weights: dict[str, float],
  657:     torch_module,
  658: ) -> object:
  659:     shifted_logits = logits[:, :-1, :].reshape(-1, vocab_size)
  660:     shifted_labels = labels[:, 1:].reshape(-1)
  661:     if not class_weights:
  662:         return torch_module.nn.functional.cross_entropy(
  663:             shifted_logits,
  664:             shifted_labels,
  665:             ignore_index=-100,
  666:         )
  667: 
  668:     token_losses = torch_module.nn.functional.cross_entropy(
  669:         shifted_logits,
  670:         shifted_labels,
  671:         ignore_index=-100,
  672:         reduction="none",
  673:     ).view(labels.shape[0], labels.shape[1] - 1)
  674:     valid_mask = (labels[:, 1:] != -100).to(token_losses.dtype)
  675:     token_counts = valid_mask.sum(dim=1).clamp_min(1.0)
  676:     example_losses = (token_losses * valid_mask).sum(dim=1) / token_counts
  677:     weight_values = [
  678:         float(class_weights.get(example.response_type, 1.0))
  679:         for example in batch
  680:     ]
  681:     example_weights = torch_module.tensor(weight_values, dtype=example_losses.dtype, device=example_losses.device)
  682:     return (example_losses * example_weights).sum() / example_weights.sum().clamp_min(1.0)
