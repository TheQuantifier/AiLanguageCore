  762: def build_token_id_remap(source_tokenizer: ByteTokenizer, target_tokenizer: ByteTokenizer) -> list[tuple[int, int]]:
  763:     pairs: list[tuple[int, int]] = []
  764: 
  765:     for char, source_id in source_tokenizer.char_to_id.items():
  766:         target_id = target_tokenizer.char_to_id.get(char)
  767:         if target_id is not None:
  768:             pairs.append((source_id, target_id))
  769: 
  770:     special_pairs = [
  771:         (source_tokenizer.pad_token_id, target_tokenizer.pad_token_id),
  772:         (source_tokenizer.bos_token_id, target_tokenizer.bos_token_id),
  773:         (source_tokenizer.eos_token_id, target_tokenizer.eos_token_id),
  774:     ]
  775:     for source_id, target_id in special_pairs:
  776:         pairs.append((int(source_id), int(target_id)))
  777: 
  778:     unique_pairs: list[tuple[int, int]] = []
  779:     seen_targets: set[int] = set()
  780:     for source_id, target_id in pairs:
  781:         if target_id in seen_targets:
  782:             continue
  783:         seen_targets.add(target_id)
  784:         unique_pairs.append((int(source_id), int(target_id)))
  785:     return unique_pairs
  786: 
  787: 
  788: def remap_vocab_matrix(
  789:     source_tensor,
  790:     target_tensor,
  791:     token_pairs: list[tuple[int, int]],
  792:     fallback_source_id: int | None = None,
  793: ):
  794:     remapped = target_tensor.clone()
  795:     source_rows = int(source_tensor.shape[0])
  796:     target_rows = int(target_tensor.shape[0])
  797:     copied_targets: set[int] = set()
  798: 
  799:     if fallback_source_id is not None and 0 <= int(fallback_source_id) < source_rows and target_rows > 0:
  800:         fallback_row = source_tensor[int(fallback_source_id)].to(dtype=target_tensor.dtype, device=target_tensor.device)
  801:         remapped[:] = fallback_row
  802: 
  803:     for source_id, target_id in token_pairs:
  804:         if source_id < 0 or target_id < 0:
  805:             continue
  806:         if source_id >= source_rows or target_id >= target_rows:
  807:             continue
  808:         remapped[target_id] = source_tensor[source_id].to(dtype=target_tensor.dtype, device=target_tensor.device)
  809:         copied_targets.add(int(target_id))
  810:     return remapped
  811: 
