 1104:     class CausalSelfAttention(nn.Module):
 1105:         def __init__(self, hidden_size: int, num_heads: int, dropout: float):
 1106:             super().__init__()
 1107:             if hidden_size % num_heads != 0:
 1108:                 raise ValueError("hidden_size must be divisible by num_heads")
 1109:             self.hidden_size = hidden_size
 1110:             self.num_heads = num_heads
 1111:             self.head_dim = hidden_size // num_heads
 1112:             self.qkv = nn.Linear(hidden_size, hidden_size * 3)
 1113:             self.proj = nn.Linear(hidden_size, hidden_size)
 1114:             self.dropout = nn.Dropout(dropout)
 1115: 
 1116:         def forward(self, x):
 1117:             batch_size, seq_len, hidden_size = x.shape
 1118:             qkv = self.qkv(x)
 1119:             q, k, v = qkv.chunk(3, dim=-1)
 1120:             q = q.view(batch_size, seq_len, self.num_heads, self.head_dim).transpose(1, 2)
 1121:             k = k.view(batch_size, seq_len, self.num_heads, self.head_dim).transpose(1, 2)
 1122:             v = v.view(batch_size, seq_len, self.num_heads, self.head_dim).transpose(1, 2)
 1123:             dropout_p = self.dropout.p if self.training else 0.0
 1124:             attn = F.scaled_dot_product_attention(q, k, v, is_causal=True, dropout_p=dropout_p)
 1125:             attn = attn.transpose(1, 2).contiguous().view(batch_size, seq_len, hidden_size)
 1126:             return self.proj(attn)
 1127: 
 1128:     class Block(nn.Module):
 1129:         def __init__(self, hidden_size: int, num_heads: int, mlp_ratio: float, dropout: float):
 1130:             super().__init__()
 1131:             mlp_hidden = int(hidden_size * mlp_ratio)
 1132:             self.norm_1 = nn.LayerNorm(hidden_size)
 1133:             self.attn = CausalSelfAttention(hidden_size, num_heads, dropout)
 1134:             self.norm_2 = nn.LayerNorm(hidden_size)
 1135:             self.mlp = nn.Sequential(
 1136:                 nn.Linear(hidden_size, mlp_hidden),
 1137:                 nn.GELU(),
 1138:                 nn.Linear(mlp_hidden, hidden_size),
 1139:                 nn.Dropout(dropout),
 1140:             )
 1141: 
 1142:         def forward(self, x):
 1143:             x = x + self.attn(self.norm_1(x))
 1144:             x = x + self.mlp(self.norm_2(x))
 1145:             return x
