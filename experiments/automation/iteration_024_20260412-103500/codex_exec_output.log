  511: 
  512:     def encode(self, text: str, add_special_tokens: bool = False) -> list[int]:
  513:         token_ids = [self.char_to_id.get(char, self.unknown_token_id) for char in text]
  514:         if add_special_tokens:
  515:             return [self.bos_token_id] + token_ids + [self.eos_token_id]
  516:         return token_ids
