  374:         answer_ids = tokenizer.encode(answer_text, add_special_tokens=False) + [tokenizer.eos_token_id]
  375:         input_ids, label_ids = fit_prompt_and_answer(prompt_ids, answer_ids, max_seq_length)
  376:         examples.append(
  377:             Example(
  378:                 input_ids=input_ids,
  379:                 label_ids=label_ids,
  380:                 response_type=answer_text,
  381:             )
  382:         )
  383:     return examples
