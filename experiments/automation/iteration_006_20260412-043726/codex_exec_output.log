  350: def fit_prompt_and_answer(prompt_ids: list[int], answer_ids: list[int], max_seq_length: int) -> tuple[list[int], list[int]]:
  351:     full_input_ids = prompt_ids + answer_ids
  352:     full_label_ids = ([-100] * len(prompt_ids)) + answer_ids
  353:     if len(full_input_ids) <= max_seq_length:
  354:         return full_input_ids, full_label_ids
  355: 
  356:     if len(answer_ids) >= max_seq_length:
  357:         trimmed_answer = answer_ids[-max_seq_length:]
  358:         return trimmed_answer, trimmed_answer[:]
  359: 
  360:     prompt_budget = max_seq_length - len(answer_ids)
  361:     trimmed_prompt = prompt_ids[-prompt_budget:] if prompt_budget > 0 else []
  362:     input_ids = trimmed_prompt + answer_ids
  363:     label_ids = ([-100] * len(trimmed_prompt)) + answer_ids
  364:     return input_ids, label_ids
