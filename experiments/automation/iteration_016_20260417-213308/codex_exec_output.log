 succeeded in 3181ms:
        answer_ids = tokenizer.encode(answer_text, add_special_tokens=False) + [tokenizer.eos_token_id]
        input_ids, label_ids = fit_prompt_and_answer(prompt_ids, answer_ids, max_seq_length)
        examples.append(
