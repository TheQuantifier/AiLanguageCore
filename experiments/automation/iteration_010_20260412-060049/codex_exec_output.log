  321: def find_best_completed_run(repo_root: Path, type_name: str | None, category_name: str | None) -> Path:
  322:     runs_root = repo_root / "models" / "runs"
  323:     status_paths = sorted(runs_root.rglob("training_status.json"), key=lambda path: path.stat().st_mtime, reverse=True)
  324:     candidates: list[tuple[tuple[float, float, float, float, float], Path]] = []
  325:     for status_path in status_paths:
  326:         try:
  327:             run_dir = status_path.parent
  328:             if not (run_dir / "model.pt").exists():
  329:                 continue
  330:             status = load_json(status_path)
  331:             if str(status.get("status", "")).lower() != "completed":
  332:                 continue
  333:             if int(status.get("global_step", 0)) <= 0:
  334:                 continue
  335:             if type_name and infer_run_type(run_dir) != type_name:
  336:                 continue
  337:             if category_name and infer_run_category(run_dir) != category_name:
  338:                 continue
  339: 
  340:             valid_output_rate, response_type_accuracy, valid_json_rate = _load_run_benchmark_metrics(run_dir)
  341:             best_validation_loss = float(status.get("best_validation_loss", 1e9))
  342:             selection_score = (
  343:                 valid_output_rate,
  344:                 response_type_accuracy,
  345:                 valid_json_rate,
  346:                 -best_validation_loss,
  347:                 parse_iso_timestamp(status.get("completed_at"))
  348:                 or parse_iso_timestamp(status.get("updated_at"))
  349:                 or parse_iso_timestamp(status.get("started_at"))
  350:                 or float(status_path.stat().st_mtime),
  351:             )
  352:             candidates.append((selection_score, run_dir))
