  800: class DirectMLAdamW:
  801:     def __init__(
  802:         self,
  803:         torch_module,
  804:         params,
  805:         lr: float,
  806:         weight_decay: float = 0.01,
  807:         betas: tuple[float, float] = (0.9, 0.999),
  808:         eps: float = 1e-8,
  809:     ) -> None:
  810:         self.torch = torch_module
  811:         self.params = [param for param in params if param.requires_grad]
  812:         self.lr = float(lr)
  813:         self.weight_decay = float(weight_decay)
  814:         self.beta1 = float(betas[0])
  815:         self.beta2 = float(betas[1])
  816:         self.eps = float(eps)
  817:         self.step_count = 0
  818:         self.state: dict[int, dict[str, object]] = {}
  819: 
  820:     def zero_grad(self, set_to_none: bool = True) -> None:
  821:         for param in self.params:
  822:             if param.grad is None:
  823:                 continue
  824:             if set_to_none:
  825:                 param.grad = None
  826:             else:
  827:                 param.grad.zero_()
  828: 
  829:     def step(self) -> None:
  830:         self.step_count += 1
  831:         bias_correction1 = 1.0 - (self.beta1 ** self.step_count)
  832:         bias_correction2 = 1.0 - (self.beta2 ** self.step_count)
  833: 
  834:         with self.torch.no_grad():
  835:             for param in self.params:
  836:                 grad = param.grad
  837:                 if grad is None:
  838:                     continue
  839:                 if grad.is_sparse:
  840:                     raise RuntimeError("DirectMLAdamW does not support sparse gradients.")

