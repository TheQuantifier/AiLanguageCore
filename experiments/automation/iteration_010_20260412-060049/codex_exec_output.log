  365: def resolve_init_model_path(path_value: str | Path | None, repo_root: Path) -> Path | None:
  366:     if not path_value:
  367:         return None
  368:     value = str(path_value).strip()
  369:     if not value:
  370:         return None
  371:     if value.startswith("latest:") or value.startswith("best:"):
  372:         mode = value.split(":", 1)[0]
  373:         parts = value.split(":")
  374:         try:
  375:             if len(parts) == 2:
  376:                 if mode == "latest":
  377:                     return find_latest_completed_run(repo_root, None, parts[1])
  378:                 return find_best_completed_run(repo_root, None, parts[1])
  379:             if len(parts) == 3:
  380:                 if mode == "latest":
  381:                     return find_latest_completed_run(repo_root, parts[1], parts[2])
  382:                 return find_best_completed_run(repo_root, parts[1], parts[2])
  383:         except FileNotFoundError:
  384:             return None
  385:         raise ValueError(
  386:             "init_from_model_path must use latest:<category>, latest:<type>:<category>, "
  387:             "best:<category>, or best:<type>:<category>"
  388:         )
  389:     return resolve_path(value, repo_root)
