  691: 
  692: def build_token_id_remap(source_tokenizer: ByteTokenizer, target_tokenizer: ByteTokenizer) -> list[tuple[int, int]]:
  693:     pairs: list[tuple[int, int]] = []
  694: 
  695:     for char, source_id in source_tokenizer.char_to_id.items():
  696:         target_id = target_tokenizer.char_to_id.get(char)
  697:         if target_id is not None:
  698:             pairs.append((source_id, target_id))
  699: 
  700:     special_pairs = [
  701:         (source_tokenizer.pad_token_id, target_tokenizer.pad_token_id),
  702:         (source_tokenizer.bos_token_id, target_tokenizer.bos_token_id),
  703:         (source_tokenizer.eos_token_id, target_tokenizer.eos_token_id),
  704:     ]
  705:     for source_id, target_id in special_pairs:
  706:         pairs.append((int(source_id), int(target_id)))
  707: 
  708:     unique_pairs: list[tuple[int, int]] = []
  709:     seen_targets: set[int] = set()
  710:     for source_id, target_id in pairs:
  711:         if target_id in seen_targets:
  712:             continue
  713:         seen_targets.add(target_id)
  714:         unique_pairs.append((int(source_id), int(target_id)))
  715:     return unique_pairs
  716: 
  717: 
  718: def remap_vocab_matrix(
  719:     source_tensor,
  720:     target_tensor,
  721:     token_pairs: list[tuple[int, int]],
  722: ):
  723:     remapped = target_tensor.clone()
  724:     source_rows = int(source_tensor.shape[0])
  725:     target_rows = int(target_tensor.shape[0])
  726:     for source_id, target_id in token_pairs:
  727:         if source_id < 0 or target_id < 0:
  728:             continue
  729:         if source_id >= source_rows or target_id >= target_rows:
  730:             continue
  731:         remapped[target_id] = source_tensor[source_id].to(dtype=target_tensor.dtype, device=target_tensor.device)
  732:     return remapped
  733: 
  734: 
  735: def transfer_position_embedding(source_tensor, target_tensor):
  736:     transferred = target_tensor.clone()
  737:     if len(source_tensor.shape) != 2 or len(target_tensor.shape) != 2:
  738:         return transferred
  739:     if int(source_tensor.shape[1]) != int(target_tensor.shape[1]):
  740:         return transferred
  741: 
  742:     rows_to_copy = min(int(source_tensor.shape[0]), int(target_tensor.shape[0]))
  743:     if rows_to_copy <= 0:
  744:         return transferred
  745:     transferred[:rows_to_copy] = source_tensor[:rows_to_copy].to(
  746:         dtype=target_tensor.dtype,
  747:         device=target_tensor.device,
  748:     )
  749:     return transferred
  750: 
  751: 
  752: def load_stage2_weights(model, init_model_dir: Path, target_tokenizer: ByteTokenizer, torch_module) -> dict[str, object]:
  753:     state_path = init_model_dir / "model.pt"
  754:     if not state_path.exists():
  755:         raise FileNotFoundError(f"Initial model checkpoint not found: {state_path}")
  756: 
  757:     source_state = torch_module.load(state_path, map_location="cpu", weights_only=False)
  758:     source_tokenizer = ByteTokenizer.from_config(load_json(init_model_dir / "tokenizer_config.json"))
  759:     token_pairs = build_token_id_remap(source_tokenizer, target_tokenizer)
  760:     target_state = model.state_dict()
  761:     updated_state = dict(target_state)
  762:     loaded_names: list[str] = []
  763:     skipped_names: list[str] = []
  764: 
  765:     for name, tensor in source_state.items():
  766:         if name not in target_state:
  767:             skipped_names.append(name)
  768:             continue
  769:         if name in {"token_embedding.weight", "lm_head.weight"}:
  770:             if len(target_state[name].shape) == 2 and len(tensor.shape) == 2 and int(target_state[name].shape[1]) == int(tensor.shape[1]):
  771:                 updated_state[name] = remap_vocab_matrix(
  772:                     source_tensor=tensor,
  773:                     target_tensor=target_state[name],
  774:                     token_pairs=token_pairs,
  775:                 )
  776:                 loaded_names.append(name)
  777:                 continue
  778:         if target_state[name].shape == tensor.shape:
  779:             updated_state[name] = tensor
  780:             loaded_names.append(name)
  781:             continue
  782:         if name == "position_embedding.weight":
  783:             updated_state[name] = transfer_position_embedding(
  784:                 source_tensor=tensor,
  785:                 target_tensor=target_state[name],
  786:             )
  787:             loaded_names.append(name)
  788:             continue
  789:         skipped_names.append(name)
  790: 
  791:     model.load_state_dict(updated_state)
  792:     return {
  793:         "loaded_count": len(loaded_names),
  794:         "skipped_count": len(skipped_names),
  795:         "loaded_names": loaded_names,
  796:         "skipped_names": skipped_names,
  797:     }
