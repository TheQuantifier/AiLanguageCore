  392: def render_messages(messages: list[dict], add_generation_prompt: bool) -> str:
  393:     parts = []
  394:     for message in messages:
  395:         role = message["role"]
  396:         prefix = ROLE_PREFIXES[role]
  397:         parts.append(prefix)
  398:         parts.append(message["content"])
  399:         parts.append("\n")
  400:     if add_generation_prompt:
  401:         parts.append(ROLE_PREFIXES["assistant"])
  402:     return "".join(parts)
