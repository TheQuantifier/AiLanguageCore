  243: def parse_iso_timestamp(value: object) -> float | None:
  244:     if not isinstance(value, str):
  245:         return None
  246:     text = value.strip()
  247:     if not text:
  248:         return None
  249:     if text.endswith("Z"):
  250:         text = f"{text[:-1]}+00:00"
  251:     try:
  252:         return datetime.fromisoformat(text).timestamp()
  253:     except ValueError:
  254:         return None
  255: 
  256: 
  257: def _load_run_benchmark_metrics(run_dir: Path) -> tuple[float, float, float]:
  258:     status_path = run_dir / "training_status.json"
  259:     if not status_path.exists():
  260:         return -1.0, -1.0, -1.0
  261:     try:
  262:         status = load_json(status_path)
  263:     except Exception:
  264:         return -1.0, -1.0, -1.0
  265: 
  266:     report_path = status.get("benchmark_report")
  267:     if not report_path:
  268:         return -1.0, -1.0, -1.0
  269:     try:
  270:         report = load_json(Path(report_path))
  271:     except Exception:
  272:         return -1.0, -1.0, -1.0
  273: 
  274:     valid_output_rate = float(report.get("valid_output_rate", -1.0))
  275:     response_type_accuracy = float(report.get("response_type_accuracy", -1.0))
  276:     valid_json_rate = float(report.get("valid_json_rate", -1.0))
  277:     return valid_output_rate, response_type_accuracy, valid_json_rate
  278: 
  279: 
  280: def find_latest_completed_run(repo_root: Path, type_name: str | None, category_name: str | None) -> Path:
  281:     runs_root = repo_root / "models" / "runs"
  282:     status_paths = sorted(
  283:         runs_root.rglob("training_status.json"),
  284:         key=lambda path: path.stat().st_mtime,
  285:         reverse=True,
  286:     )
  287:     candidates: list[tuple[float, Path]] = []
  288:     for status_path in status_paths:
  289:         try:
  290:             run_dir = status_path.parent
  291:             if not (run_dir / "model.pt").exists():
  292:                 continue
  293:             status = load_json(status_path)
  294:             if str(status.get("status", "")).lower() != "completed":
  295:                 continue
  296:             if int(status.get("global_step", 0)) <= 0:
  297:                 continue
  298:             if type_name and infer_run_type(run_dir) != type_name:
  299:                 continue

