  405: class ByteTokenizer:
  406:     def __init__(
  407:         self,
  408:         chars: list[str],
  409:         pad_token_id: int | None = None,
  410:         bos_token_id: int | None = None,
  411:         eos_token_id: int | None = None,
  412:     ):
  413:         ordered_chars = []
  414:         seen = set()
  415:         for char in chars:
  416:             if len(char) != 1:
  417:                 continue
  418:             if char in seen:
  419:                 continue
  420:             ordered_chars.append(char)
  421:             seen.add(char)
  422:         if "?" not in seen:
  423:             ordered_chars.append("?")
  424:             seen.add("?")
  425:         self.chars = ordered_chars
  426:         self.char_to_id = {char: index for index, char in enumerate(self.chars)}
  427:         self.id_to_char = {index: char for char, index in self.char_to_id.items()}
  428:         self.unknown_token_id = self.char_to_id["?"]
  429:         regular_token_limit = len(self.chars)
  430:         self.regular_token_limit = regular_token_limit

