import json
from collections import Counter
from pathlib import Path
for path in ['data/processed/train.json','data/processed/validation.json','data/processed/full_dataset.json']:
    rows=json.loads(Path(path).read_text())
    counts=Counter(r['response_type'] for r in rows)
    print(path, len(rows), dict(sorted(counts.items())))
queries=[
'Can you break that down a bit for me?','Can you explain this for me?','Can you help me choose?','Could you compare these for me?','What should I do after that?','Is that enough to get started?',
'Can you break down what a spending limit is?','Can you explain what opportunity cost means in simple words?','Can you help me choose between needs and wants?','Could you compare fixed costs and variable costs?','What should I do after I list my monthly expenses?','Is an emergency fund enough for small unexpected costs?'
]
train=json.loads(Path('data/processed/train.json').read_text())
val=json.loads(Path('data/processed/validation.json').read_text())
for q in queries:
    t=[r['response_type'] for r in train if r['user_input']==q]
    v=[r['response_type'] for r in val if r['user_input']==q]
    print(q, 'train', t, 'val', v)
