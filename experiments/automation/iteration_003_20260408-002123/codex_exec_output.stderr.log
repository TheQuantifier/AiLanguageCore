from pathlib import Path
report=json.loads(Path('experiments/benchmark_report-v1-native-byte-transformer-20260408-002124.json').read_text())
cm=defaultdict(Counter)
for r in report['results']:
    cm[r['expected_response_type']][r['predicted_response_type'] or 'INVALID'] += 1
for exp in ['CLARIFICATION','DIRECT_ANSWER','TOOL_NEEDED','OUT_OF_SCOPE']:
    print(exp, dict(cm[exp]))
print('\\nTop confusions:')
conf=Counter()
for exp,row in cm.items():
    for pred,count in row.items():
        if pred"'!=exp:
            conf[(exp,pred)] += count
for (exp,pred),count in conf.most_common():
    print(count, exp, '"'->', pred)
