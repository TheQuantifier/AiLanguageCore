  304: def render_messages(messages: list[dict], add_generation_prompt: bool) -> str:
  305:     parts = []
  306:     for message in messages:
  307:         role = message["role"]
  308:         prefix = ROLE_PREFIXES[role]
  309:         parts.append(prefix)
  310:         parts.append(message["content"])
