  419:         answer_text = row["messages"][2]["content"]
  420: 
  421:         prompt_ids = [tokenizer.bos_token_id] + tokenizer.encode(prompt_text, add_special_tokens=False)
  422:         answer_ids = tokenizer.encode(answer_text, add_special_tokens=False) + [tokenizer.eos_token_id]
  423:         input_ids, label_ids = fit_prompt_and_answer(prompt_ids, answer_ids, max_seq_length)
  424:         examples.append(
  425:             Example(
  426:                 input_ids=input_ids,
  427:                 label_ids=label_ids,
  428:                 response_type=answer_text,
  429:             )
  430:         )
