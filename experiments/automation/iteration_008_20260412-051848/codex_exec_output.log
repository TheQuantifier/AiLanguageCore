  603: 
  604: def build_token_id_remap(source_tokenizer: ByteTokenizer, target_tokenizer: ByteTokenizer) -> list[tuple[int, int]]:
  605:     pairs: list[tuple[int, int]] = []
  606: 
  607:     for char, source_id in source_tokenizer.char_to_id.items():
  608:         target_id = target_tokenizer.char_to_id.get(char)
  609:         if target_id is not None:
  610:             pairs.append((source_id, target_id))
  611: 
  612:     special_pairs = [
  613:         (source_tokenizer.pad_token_id, target_tokenizer.pad_token_id),
  614:         (source_tokenizer.bos_token_id, target_tokenizer.bos_token_id),
  615:         (source_tokenizer.eos_token_id, target_tokenizer.eos_token_id),
  616:     ]
  617:     for source_id, target_id in special_pairs:
  618:         pairs.append((int(source_id), int(target_id)))
  619: 
  620:     unique_pairs: list[tuple[int, int]] = []
  621:     seen_targets: set[int] = set()
  622:     for source_id, target_id in pairs:
  623:         if target_id in seen_targets:
  624:             continue
  625:         seen_targets.add(target_id)
  626:         unique_pairs.append((int(source_id), int(target_id)))
  627:     return unique_pairs
  628: 
  629: 
  630: def remap_vocab_matrix(
  631:     source_tensor,
  632:     target_tensor,
  633:     token_pairs: list[tuple[int, int]],
  634: ):
  635:     remapped = target_tensor.clone()
  636:     source_rows = int(source_tensor.shape[0])
  637:     target_rows = int(target_tensor.shape[0])
  638:     for source_id, target_id in token_pairs:
  639:         if source_id < 0 or target_id < 0:
  640:             continue
  641:         if source_id >= source_rows or target_id >= target_rows:
  642:             continue
  643:         remapped[target_id] = source_tensor[source_id].to(dtype=target_tensor.dtype, device=target_tensor.device)
  644:     return remapped
  645: 
  646: 
  647: def transfer_position_embedding(source_tensor, target_tensor):
  648:     transferred = target_tensor.clone()
  649:     if len(source_tensor.shape) != 2 or len(target_tensor.shape) != 2:
  650:         return transferred
  651:     if int(source_tensor.shape[1]) != int(target_tensor.shape[1]):
  652:         return transferred
  653: 
  654:     rows_to_copy = min(int(source_tensor.shape[0]), int(target_tensor.shape[0]))
  655:     if rows_to_copy <= 0:
  656:         return transferred
  657:     transferred[:rows_to_copy] = source_tensor[:rows_to_copy].to(
  658:         dtype=target_tensor.dtype,
  659:         device=target_tensor.device,
  660:     )
  661:     return transferred
  662: 
  663: 
  664: def load_stage2_weights(model, init_model_dir: Path, target_tokenizer: ByteTokenizer, torch_module) -> dict[str, object]:
  665:     state_path = init_model_dir / "model.pt"
  666:     if not state_path.exists():
  667:         raise FileNotFoundError(f"Initial model checkpoint not found: {state_path}")
  668: 
  669:     source_state = torch_module.load(state_path, map_location="cpu", weights_only=False)
  670:     source_tokenizer = ByteTokenizer.from_config(load_json(init_model_dir / "tokenizer_config.json"))
  671:     token_pairs = build_token_id_remap(source_tokenizer, target_tokenizer)
  672:     target_state = model.state_dict()
  673:     updated_state = dict(target_state)
  674:     loaded_names: list[str] = []
  675:     skipped_names: list[str] = []
  676: 
  677:     for name, tensor in source_state.items():
  678:         if name not in target_state:
  679:             skipped_names.append(name)
  680:             continue
  681:         if name in {"token_embedding.weight", "lm_head.weight"}:
  682:             if len(target_state[name].shape) == 2 and len(tensor.shape) == 2 and int(target_state[name].shape[1]) == int(tensor.shape[1]):
  683:                 updated_state[name] = remap_vocab_matrix(
  684:                     source_tensor=tensor,
  685:                     target_tensor=target_state[name],
  686:                     token_pairs=token_pairs,
  687:                 )
  688:                 loaded_names.append(name)
  689:                 continue
  690:         if target_state[name].shape == tensor.shape:
  691:             updated_state[name] = tensor
  692:             loaded_names.append(name)
  693:             continue
  694:         if name == "position_embedding.weight":
  695:             updated_state[name] = transfer_position_embedding(
  696:                 source_tensor=tensor,
  697:                 target_tensor=target_state[name],
  698:             )
  699:             loaded_names.append(name)
  700:             continue
  701:         skipped_names.append(name)
  702: 
  703:     model.load_state_dict(updated_state)
  704:     return {
  705:         "loaded_count": len(loaded_names),
  706:         "skipped_count": len(skipped_names),
  707:         "loaded_names": loaded_names,
  708:         "skipped_names": skipped_names,
  709:     }
