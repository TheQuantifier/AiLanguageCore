  317: class ByteTokenizer:
  318:     def __init__(
  319:         self,
  320:         chars: list[str],
  321:         pad_token_id: int | None = None,
  322:         bos_token_id: int | None = None,
  323:         eos_token_id: int | None = None,
  324:     ):
  325:         ordered_chars = []
  326:         seen = set()
  327:         for char in chars:
  328:             if len(char) != 1:
  329:                 continue
  330:             if char in seen:
  331:                 continue
  332:             ordered_chars.append(char)
  333:             seen.add(char)
  334:         if "?" not in seen:
  335:             ordered_chars.append("?")
  336:             seen.add("?")
  337:         self.chars = ordered_chars
  338:         self.char_to_id = {char: index for index, char in enumerate(self.chars)}
  339:         self.id_to_char = {index: char for char, index in self.char_to_id.items()}
  340:         self.unknown_token_id = self.char_to_id["?"]
  341:         regular_token_limit = len(self.chars)
  342:         self.regular_token_limit = regular_token_limit
  343:         self.pad_token_id = int(regular_token_limit if pad_token_id is None else pad_token_id)
  344:         self.bos_token_id = int(regular_token_limit + 1 if bos_token_id is None else bos_token_id)
  345:         self.eos_token_id = int(regular_token_limit + 2 if eos_token_id is None else eos_token_id)
  346:         self.vocab_size = max(regular_token_limit, self.pad_token_id, self.bos_token_id, self.eos_token_id) + 1
  347: 
  348:     @classmethod
  349:     def from_config(cls, payload: dict) -> "ByteTokenizer":
  350:         chars = payload.get("chars")
  351:         if chars:
  352:             return cls(
  353:                 chars=list(chars),
  354:                 pad_token_id=int(payload["pad_token_id"]),
  355:                 bos_token_id=int(payload["bos_token_id"]),
  356:                 eos_token_id=int(payload["eos_token_id"]),
  357:             )
  358:         regular_token_limit = int(payload.get("regular_token_limit", payload.get("vocab_size", 131) - 3))
  359:         chars = [chr(index) for index in range(regular_token_limit)]
  360:         return cls(
  361:             chars=chars,
  362:             pad_token_id=int(payload["pad_token_id"]),
  363:             bos_token_id=int(payload["bos_token_id"]),
  364:             eos_token_id=int(payload["eos_token_id"]),
  365:         )
  366: 
  367:     def encode(self, text: str, add_special_tokens: bool = False) -> list[int]:
  368:         token_ids = [self.char_to_id.get(char, self.unknown_token_id) for char in text]
  369:         if add_special_tokens:
  370:             return [self.bos_token_id] + token_ids + [self.eos_token_id]
  371:         return token_ids
  372: 
  373:     def decode(self, token_ids: list[int]) -> str:
  374:         return "".join(self.id_to_char[token_id] for token_id in token_ids if token_id in self.id_to_char)
