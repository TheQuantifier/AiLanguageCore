  712: class DirectMLAdamW:
  713:     def __init__(
  714:         self,
  715:         torch_module,
  716:         params,
  717:         lr: float,
  718:         weight_decay: float = 0.01,
  719:         betas: tuple[float, float] = (0.9, 0.999),
  720:         eps: float = 1e-8,
  721:     ) -> None:
  722:         self.torch = torch_module
  723:         self.params = [param for param in params if param.requires_grad]
  724:         self.lr = float(lr)
  725:         self.weight_decay = float(weight_decay)
  726:         self.beta1 = float(betas[0])
  727:         self.beta2 = float(betas[1])
  728:         self.eps = float(eps)
  729:         self.step_count = 0
  730:         self.state: dict[int, dict[str, object]] = {}
  731: 
  732:     def zero_grad(self, set_to_none: bool = True) -> None:
  733:         for param in self.params:
  734:             if param.grad is None:
  735:                 continue
  736:             if set_to_none:
  737:                 param.grad = None
  738:             else:
  739:                 param.grad.zero_()
  740: 
  741:     def step(self) -> None:
  742:         self.step_count += 1
  743:         bias_correction1 = 1.0 - (self.beta1 ** self.step_count)
  744:         bias_correction2 = 1.0 - (self.beta2 ** self.step_count)
  745: 
  746:         with self.torch.no_grad():
  747:             for param in self.params:
  748:                 grad = param.grad
  749:                 if grad is None:
  750:                     continue
  751:                 if grad.is_sparse:
  752:                     raise RuntimeError("DirectMLAdamW does not support sparse gradients.")
  753: 
  754:                 state = self.state.get(id(param))
  755:                 if state is None:
  756:                     state = {
  757:                         "exp_avg": self.torch.zeros_like(param),
  758:                         "exp_avg_sq": self.torch.zeros_like(param),
  759:                     }
  760:                     self.state[id(param)] = state

