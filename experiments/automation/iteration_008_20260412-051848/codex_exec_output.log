  434: def build_tokenizer_from_rows(*row_sets: list[dict]) -> ByteTokenizer:
  435:     chars = set()
  436:     for rows in row_sets:
  437:         for row in rows:
  438:             for message in row["messages"]:
  439:                 chars.update(message["content"])
  440:     return ByteTokenizer(chars=sorted(chars))
