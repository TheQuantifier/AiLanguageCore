  462: 
  463: def compute_response_type_weights(
  464:     examples: list[Example],
  465:     enabled: bool,
  466:     weight_power: float,
  467: ) -> dict[str, float]:
  468:     if not enabled or not examples:
  469:         return {}
  470: 
  471:     counts: dict[str, int] = {}
  472:     for example in examples:
  473:         counts[example.response_type] = counts.get(example.response_type, 0) + 1
  474: 
  475:     if not counts:
  476:         return {}
  477: 
  478:     total_examples = len(examples)
  479:     total_classes = len(counts)
  480:     normalized_weights = {
  481:         response_type: ((total_examples / (total_classes * count)) ** weight_power)
  482:         for response_type, count in counts.items()
  483:     }
  484:     mean_weight = sum(normalized_weights.values()) / len(normalized_weights)
  485:     if mean_weight <= 0:
  486:         return {}
  487:     return {
  488:         response_type: (weight / mean_weight)
  489:         for response_type, weight in normalized_weights.items()
  490:     }
  491: 
  492: 
  493: def compute_batch_loss(
  494:     logits,
  495:     labels,
  496:     batch: list[Example],
  497:     vocab_size: int,
  498:     class_weights: dict[str, float],
  499:     torch_module,
  500: ) -> object:
  501:     shifted_logits = logits[:, :-1, :].reshape(-1, vocab_size)
  502:     shifted_labels = labels[:, 1:].reshape(-1)
  503:     if not class_weights:
  504:         return torch_module.nn.functional.cross_entropy(
  505:             shifted_logits,
  506:             shifted_labels,
  507:             ignore_index=-100,
  508:         )
  509: 
  510:     token_losses = torch_module.nn.functional.cross_entropy(
  511:         shifted_logits,
  512:         shifted_labels,
  513:         ignore_index=-100,
  514:         reduction="none",
  515:     ).view(labels.shape[0], labels.shape[1] - 1)
  516:     valid_mask = (labels[:, 1:] != -100).to(token_losses.dtype)
  517:     token_counts = valid_mask.sum(dim=1).clamp_min(1.0)
  518:     example_losses = (token_losses * valid_mask).sum(dim=1) / token_counts
  519:     weight_values = [
  520:         float(class_weights.get(example.response_type, 1.0))
  521:         for example in batch
  522:     ]
  523:     example_weights = torch_module.tensor(weight_values, dtype=example_losses.dtype, device=example_losses.device)
  524:     return (example_losses * example_weights).sum() / example_weights.sum().clamp_min(1.0)
