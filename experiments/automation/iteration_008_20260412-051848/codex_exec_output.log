  443: def create_batches(examples: list[Example], batch_size: int, shuffle: bool) -> list[list[Example]]:
  444:     items = examples[:]
  445:     if shuffle:
  446:         random.shuffle(items)
  447:     return [items[index : index + batch_size] for index in range(0, len(items), batch_size)]
  448: 
  449: 
  450: def collate_batch(batch: list[Example], tokenizer: ByteTokenizer, torch_module) -> tuple[object, object]:
  451:     max_length = max(len(example.input_ids) for example in batch)
  452:     input_rows = []
  453:     label_rows = []
  454:     for example in batch:
  455:         pad_count = max_length - len(example.input_ids)
  456:         input_rows.append(example.input_ids + ([tokenizer.pad_token_id] * pad_count))
  457:         label_rows.append(example.label_ids + ([-100] * pad_count))
  458:     input_ids = torch_module.tensor(input_rows, dtype=torch_module.long)
  459:     labels = torch_module.tensor(label_rows, dtype=torch_module.long)
  460:     return input_ids, labels
