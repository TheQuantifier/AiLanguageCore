    function ConvertTo-CommandLineArgument {
        param(
            [string]$Value
        )

        if ($null -eq $Value) {
            return '""'
        }

        if ($Value -eq '') {
            return '""'
        }

        if ($Value -notmatch '[\s"]') {
            return $Value
        }

        $escaped = $Value -replace '(\\*)"', '$1$1\"'
        $escaped = $escaped -replace '(\\+)$', '$1$1'
        return ('"{0}"' -f $escaped)
    }

