    line = (
        f"{render_progress_bar(current, total)} | "
        f"nonempty_output={nonempty_output} | "
        f"valid_output={valid_output} | "
        f"correct_type={correct_response_type} | "
        f"items_per_sec={rate:.2f}"
    )
    sys.stdout.write("\r" + line + " " * 8)
    sys.stdout.flush()


