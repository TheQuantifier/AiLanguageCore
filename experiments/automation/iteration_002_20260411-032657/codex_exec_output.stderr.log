import json,re
from pathlib import Path

def load(p):
    with open(p,'r',encoding='utf-8') as f: return json.load(f)

def k(s):
    return re.sub(r'\\s+',' ',s.strip()).lower()

new=load('data/curated/native_boundary_boost_v2.json')[-5:]
val=load('data/processed/validation.json')
bench=load('data/processed/benchmark.json')
focused=[]
for p in [
'data/processed/benchmark_stress.json',
'data/processed/benchmark_stress_v2.json',
'data/processed/benchmark_account_tool_boundary.json',
'data/processed/benchmark_medical_refusal_boundary.json',
'data/processed/benchmark_oos_vs_tool_boundary.json']:
    if Path(p).exists(): focused += load(p)
blocked={k(r['user_input']) for r in (val+bench+focused)}
train=load('data/processed/train.json')
base={k(r['user_input']) for r in train}
for r in new:
    key=k(r['user_input'])
    print(r['id'], 'blocked_eval='+str(key in blocked), 'already_train='+str(key in base))
