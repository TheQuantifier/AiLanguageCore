 1101:     class CausalSelfAttention(nn.Module):
 1102:         def __init__(self, hidden_size: int, num_heads: int, dropout: float):
 1103:             super().__init__()
 1104:             if hidden_size % num_heads != 0:
 1105:                 raise ValueError("hidden_size must be divisible by num_heads")
 1106:             self.hidden_size = hidden_size
 1107:             self.num_heads = num_heads
 1108:             self.head_dim = hidden_size // num_heads
 1109:             self.qkv = nn.Linear(hidden_size, hidden_size * 3)
 1110:             self.proj = nn.Linear(hidden_size, hidden_size)
 1111:             self.dropout = nn.Dropout(dropout)
 1112: 
 1113:         def forward(self, x):
 1114:             batch_size, seq_len, hidden_size = x.shape
 1115:             qkv = self.qkv(x)
 1116:             q, k, v = qkv.chunk(3, dim=-1)
 1117:             q = q.view(batch_size, seq_len, self.num_heads, self.head_dim).transpose(1, 2)
 1118:             k = k.view(batch_size, seq_len, self.num_heads, self.head_dim).transpose(1, 2)
 1119:             v = v.view(batch_size, seq_len, self.num_heads, self.head_dim).transpose(1, 2)
 1120:             dropout_p = self.dropout.p if self.training else 0.0
 1121:             attn = F.scaled_dot_product_attention(q, k, v, is_causal=True, dropout_p=dropout_p)
 1122:             attn = attn.transpose(1, 2).contiguous().view(batch_size, seq_len, hidden_size)
 1123:             return self.proj(attn)
