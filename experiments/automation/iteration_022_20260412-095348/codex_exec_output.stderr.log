 1125:     class Block(nn.Module):
 1126:         def __init__(self, hidden_size: int, num_heads: int, mlp_ratio: float, dropout: float):
 1127:             super().__init__()
 1128:             mlp_hidden = int(hidden_size * mlp_ratio)
 1129:             self.norm_1 = nn.LayerNorm(hidden_size)
 1130:             self.attn = CausalSelfAttention(hidden_size, num_heads, dropout)
 1131:             self.norm_2 = nn.LayerNorm(hidden_size)
 1132:             self.mlp = nn.Sequential(
 1133:                 nn.Linear(hidden_size, mlp_hidden),
 1134:                 nn.GELU(),
 1135:                 nn.Linear(mlp_hidden, hidden_size),
 1136:                 nn.Dropout(dropout),
 1137:             )
 1138: 
 1139:         def forward(self, x):
 1140:             x = x + self.attn(self.norm_1(x))
 1141:             x = x + self.mlp(self.norm_2(x))
 1142:             return x
